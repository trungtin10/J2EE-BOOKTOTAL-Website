<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <title>Chi tiết Sản phẩm - Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body>
    <div class="container mt-5">
        <div class="card shadow">
            <div class="card-header bg-info text-white d-flex justify-content-between align-items-center">
                <h4 class="mb-0">Chi tiết Sản phẩm #<%= item.id %></h4>
                <a href="/admin/products" class="btn btn-light btn-sm text-dark fw-bold">
                    <i class="fas fa-arrow-left"></i> Quay lại
                </a>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-4 text-center">
                        <%
                            let imgSrc = item.image_url;
                            if (imgSrc && !imgSrc.startsWith('http')) {
                                imgSrc = '/images/' + imgSrc;
                            }
                        %>
                        <img src="<%= imgSrc ? imgSrc : '/images/default.jpg' %>"
                             class="img-fluid rounded shadow-sm"
                             style="max-height: 400px;"
                             onerror="this.src='https://picsum.photos/200/300?random=<%= item.id %>'">
                    </div>
                    <div class="col-md-8">
                        <h3 class="text-primary"><%= item.name %></h3>
                        <p class="text-muted">Tác giả: <strong><%= item.author %></strong></p>

                        <hr>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <h5>Giá bán:</h5>
                                <p class="text-danger fw-bold fs-4">
                                    <!-- Ép kiểu Number -->
                                    <%= Number(item.price).toLocaleString('vi-VN') %> đ
                                </p>
                            </div>
                            <div class="col-md-6">
                                <h5>Số lượng tồn kho:</h5>
                                <p class="fw-bold fs-4"><%= item.quantity %></p>
                            </div>
                        </div>

                        <div class="mb-3">
                            <h5>Mô tả:</h5>
                            <p><%= item.description || "Chưa có mô tả." %></p>
                        </div>

                        <div class="mb-3">
                            <h5>Danh mục:</h5>
                            <span class="badge bg-secondary"><%= item.category_name || "Chưa phân loại" %></span>
                        </div>

                        <hr>

                        <div class="d-flex gap-2">
                            <a href="/admin/products/edit/<%= item.id %>" class="btn btn-primary">
                                <i class="fas fa-edit"></i> Chỉnh sửa
                            </a>
                            <a href="/admin/products/delete/<%= item.id %>"
                               class="btn btn-danger"
                               onclick="return confirm('Bạn có chắc muốn xóa sách này?');">
                                <i class="fas fa-trash"></i> Xóa sản phẩm
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>
</html>