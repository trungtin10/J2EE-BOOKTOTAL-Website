<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="referrer" content="no-referrer">
    <title>Trang Quản Trị - Danh Sách Sản Phẩm</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <style>
        body { background-color: #f8f9fa; }
        .admin-header {
            background-color: #1a1a2e; 
            color: white;
            padding: 15px 20px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-bottom: 3px solid #c49b63; 
        }
        .sidebar {
            min-height: 100vh;
            background-color: #fff;
            padding-top: 20px;
            border-right: 1px solid #ddd;
        }
        .sidebar a {
            display: block;
            padding: 12px 15px;
            color: #333;
            text-decoration: none;
            margin-bottom: 5px;
            font-weight: 500;
            transition: 0.2s;
        }
        .sidebar a:hover { background-color: #f0f0f0; color: #0d6efd; }
        .sidebar a.active {
            background-color: #e9ecef;
            color: #0d6efd;
            border-left: 4px solid #0d6efd;
        }
        .main-content { padding: 20px; }
        .page-title {
            font-size: 24px;
            font-weight: bold;
            color: #333;
            margin-bottom: 20px;
            border-bottom: 2px solid #c49b63;
            display: inline-block;
            padding-bottom: 5px;
        }
        .product-img {
            width: 60px;
            height: 80px;
            object-fit: cover;
            border: 1px solid #ddd;
            border-radius: 4px;
            background-color: #eee;
        }
        .action-btn { 
            margin-right: 2px; 
            width: 32px;
            height: 32px;
            padding: 0;
            display: inline-flex;
            align-items: center;
            justify-content: center;
        }
    </style>
</head>
<body>

    <div class="admin-header">
        <h2>Khu vực quản trị</h2>
    </div>

    <div class="container-fluid">
        <div class="row">
            <div class="col-md-2 sidebar">
                <a href="/admin" class="active"><i class="fas fa-box me-2"></i> Quản lý Sản phẩm</a>
                <a href="/admin/user"><i class="fas fa-users me-2"></i> Quản lý Người dùng</a>
                <a href="/admin/orders"><i class="fas fa-shopping-cart me-2"></i> Quản lý Đơn hàng</a>
                <a href="/admin/statistics"><i class="fas fa-chart-line me-2"></i> Thống kê</a>
                <a href="/admin/warehouse"><i class="fas fa-warehouse me-2"></i> Quản lý kho hàng</a>
                <hr>
                <a href="/"><i class="fas fa-home me-2"></i> Về trang chủ</a>
            </div>

            <div class="col-md-10 main-content">
                <h3 class="page-title"><i class="fas fa-book-open"></i> Danh sách truyện sách</h3>
                
                <div class="mb-3">
                    <a href="/admin/create" class="btn btn-success">
                        <i class="fas fa-plus"></i> Thêm mới sản phẩm
                    </a>
                </div>

                <div class="card shadow-sm border-0">
                    <div class="card-body p-0">
                        <table class="table table-bordered table-hover mb-0 align-middle">
                            <thead class="table-dark">
                                <tr>
                                    <th>Ảnh</th>
                                    <th>Tên truyện</th>
                                    <th>Giá</th>
                                    <th>Danh mục</th>
                                    <th>Mô tả</th>
                                    <th>Số lượng</th>
                                    <th style="width: 160px;">Thao tác</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% if (products && products.length > 0) { %>
                                    <% products.forEach(function(item) { %>
                                        <tr>
                                            <td>
                                                <% 
                                                    let imgSrc = item.image_url;
                                                    if (imgSrc && !imgSrc.startsWith('http')) {
                                                        imgSrc = '/images/' + imgSrc;
                                                    }
                                                %>
                                                <img src="<%= imgSrc ? imgSrc : '/images/default.jpg' %>" 
                                                     class="product-img" 
                                                     onerror="this.src='https://picsum.photos/200/300?random=<%= item.id %>'">
                                            </td>
                                            <td class="fw-bold"><%= item.name %></td>
                                            <td class="text-danger fw-bold">
                                                <%= new Intl.NumberFormat('vi-VN').format(item.price) %> đ
                                            </td>
                                            <td><%= item.category_name || 'Truyện tranh' %></td>
                                            <td>
                                                <small><%= item.description ? item.description.substring(0, 40) + '...' : 'Không có mô tả' %></small>
                                            </td>
                                            <td class="text-center fw-bold"><%= item.quantity %></td>
                                            <td>
                                                <a href="/admin/view/<%= item.id %>" class="btn btn-info btn-sm action-btn text-white" title="Xem">
                                                    <i class="fas fa-eye"></i>
                                                </a>
                                                <a href="/admin/edit/<%= item.id %>" class="btn btn-warning btn-sm action-btn" title="Sửa">
                                                    <i class="fas fa-pen"></i>
                                                </a>
                                                <a href="/admin/delete/<%= item.id %>" class="btn btn-danger btn-sm action-btn" onclick="return confirm('Xóa sản phẩm này?')" title="Xóa">
                                                    <i class="fas fa-trash"></i>
                                                </a>
                                            </td>
                                        </tr>
                                    <% }); %>
                                <% } else { %>
                                    <tr>
                                        <td colspan="7" class="text-center p-4">Chưa có sản phẩm nào.</td>
                                    </tr>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div> 
        </div>
    </div>
</body>
</html>