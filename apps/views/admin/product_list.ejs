<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <title>Quản lý Sản phẩm - Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body>
    <nav class="navbar navbar-dark bg-dark mb-4">
        <div class="container">
            <a class="navbar-brand" href="/admin">ADMIN DASHBOARD</a>
            <div>
                <a href="/admin" class="btn btn-outline-light btn-sm me-2">
                    <i class="fas fa-arrow-left"></i> Quay lại Dashboard
                </a>
                <a href="/" class="btn btn-outline-light btn-sm me-2">
                    <i class="fas fa-home"></i> Trang Chủ
                </a>
            </div>
        </div>
    </nav>

    <div class="container">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2>Danh sách Sản phẩm</h2>
            <a href="/admin/products/add" class="btn btn-success"><i class="fas fa-plus"></i> Thêm sản phẩm mới</a>
        </div>

        <div class="table-responsive">
            <table class="table table-bordered table-hover shadow-sm align-middle">
                <thead class="table-light">
                    <tr>
                        <th style="width: 50px;">ID</th>
                        <th style="width: 100px;">Hình ảnh</th>
                        <th>Tên sách</th>
                        <th>Tác giả</th>
                        <th>Giá</th>
                        <th>Số lượng</th>
                        <th style="width: 200px;">Hành động</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (products && products.length > 0) { %>
                        <% products.forEach(item => { %>
                            <tr>
                                <td><%= item.id %></td>
                                <td>
                                    <%
                                        let imgSrc = item.image_url;
                                        if (imgSrc && !imgSrc.startsWith('http')) {
                                            imgSrc = '/images/' + imgSrc;
                                        }
                                    %>
                                    <img src="<%= imgSrc ? imgSrc : '/images/default.jpg' %>"
                                         alt="Book cover"
                                         style="width: 60px; height: 80px; object-fit: cover;"
                                         onerror="this.src='https://picsum.photos/200/300?random=<%= item.id %>'">
                                </td>
                                <td class="fw-bold"><%= item.name %></td>
                                <td><%= item.author %></td>
                                <td class="text-danger fw-bold">
                                    <!-- Ép kiểu Number -->
                                    <%= Number(item.price).toLocaleString('vi-VN') %> đ
                                </td>
                                <td><%= item.quantity %></td>
                                <td>
                                    <a href="/admin/products/detail/<%= item.id %>" class="btn btn-info btn-sm me-1 text-white" title="Xem chi tiết">
                                        <i class="fas fa-eye"></i>
                                    </a>
                                    <a href="/admin/products/edit/<%= item.id %>" class="btn btn-primary btn-sm me-1" title="Sửa">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                    <a href="/admin/products/delete/<%= item.id %>"
                                       class="btn btn-danger btn-sm"
                                       onclick="return confirm('Bạn có chắc muốn xóa sách này?');" title="Xóa">
                                        <i class="fas fa-trash"></i>
                                    </a>
                                </td>
                            </tr>
                        <% }); %>
                    <% } else { %>
                        <tr>
                            <td colspan="7" class="text-center py-4">Chưa có sản phẩm nào.</td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>
</body>
</html>