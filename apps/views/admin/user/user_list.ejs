<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <title>Quản lý User - Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body>
    <nav class="navbar navbar-dark bg-dark mb-4">
        <div class="container">
            <a class="navbar-brand" href="/admin">ADMIN DASHBOARD</a>
            <div>
                <a href="/admin" class="btn btn-outline-light btn-sm me-2">
                    <i class="fas fa-arrow-left"></i> Quay lại Dashboard
                </a>
                <a href="/" class="btn btn-outline-light btn-sm me-2">
                    <i class="fas fa-home"></i> Trang Chủ
                </a>
            </div>
        </div>
    </nav>

    <div class="container">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h2>Danh sách Người dùng</h2>
            <!-- Link trỏ vào route thêm user -->
            <a href="/admin/user/add" class="btn btn-success"><i class="fas fa-user-plus"></i> Thêm người dùng</a>
        </div>

        <table class="table table-bordered table-hover shadow-sm">
            <thead class="table-light">
                <tr>
                    <th>ID</th>
                    <th>Username</th>
                    <th>Mật khẩu</th> <!-- Thêm cột Mật khẩu -->
                    <th>Họ tên</th>
                    <th>Email</th>
                    <th>Vai trò</th>
                    <th>Hành động</th>
                </tr>
            </thead>
            <tbody>
                <% if (users && users.length > 0) { %>
                    <% users.forEach(user => { %>
                        <tr>
                            <td><%= user.id %></td>
                            <td><%= user.username %></td>
                            <td><%= user.password %></td> <!-- Hiển thị mật khẩu -->
                            <td><%= user.full_name %></td>
                            <td><%= user.email %></td>
                            <td>
                                <% if (user.role && user.role.toLowerCase() === 'admin') { %>
                                    <span class="badge bg-danger">Admin</span>
                                <% } else { %>
                                    <span class="badge bg-primary">User</span>
                                <% } %>
                            </td>
                            <td>
                                <!-- Đã xóa nút Sửa -->
                                <a href="/admin/user/delete/<%= user.id %>"
                                   class="btn btn-danger btn-sm"
                                   onclick="return confirm('CẢNH BÁO: Bạn có chắc muốn xóa user này? (Kể cả Admin)');">
                                    <i class="fas fa-trash"></i> Xóa
                                </a>
                            </td>
                        </tr>
                    <% }); %>
                <% } else { %>
                    <tr>
                        <td colspan="7" class="text-center">Chưa có user nào.</td>
                    </tr>
                <% } %>
            </tbody>
        </table>
    </div>
</body>
</html>