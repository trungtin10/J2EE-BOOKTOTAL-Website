<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <title>Giỏ hàng - Bookstore</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        body {
            background-color: #f0f2f5;
            font-family: 'Segoe UI', sans-serif;
            display: flex;
            flex-direction: column;
            min-height: 100vh;
        }

        .main-content { flex: 1; }

        .cart-container {
            background: white;
            border-radius: 12px;
            padding: 20px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.05);
            margin-top: 30px;
        }

        .cart-header {
            font-weight: 700;
            color: #333;
            border-bottom: 2px solid #eee;
            padding-bottom: 15px;
            margin-bottom: 15px;
            font-size: 1.1rem;
        }

        .cart-item {
            border-bottom: 1px solid #f0f0f0;
            padding: 15px 0;
            display: flex;
            align-items: center;
        }

        .cart-item:last-child { border-bottom: none; }

        .item-checkbox {
            width: 18px;
            height: 18px;
            margin-right: 15px;
            cursor: pointer;
        }

        .item-img {
            width: 60px;
            height: 80px;
            object-fit: cover;
            border-radius: 6px;
            margin-right: 15px;
        }

        .item-info { flex: 1; }
        .item-name { font-weight: 600; color: #333; font-size: 1rem; margin-bottom: 4px; }
        .item-price { color: #C92127; font-weight: 700; font-size: 0.95rem; }

        .qty-control {
            display: flex;
            align-items: center;
            border: 1px solid #ddd;
            border-radius: 4px;
            width: 90px;
            height: 32px;
        }
        .qty-btn {
            background: none;
            border: none;
            padding: 0 10px;
            cursor: pointer;
            color: #555;
            text-decoration: none;
            font-size: 1.2rem;
            line-height: 1;
        }
        .qty-input {
            width: 30px;
            text-align: center;
            border: none;
            outline: none;
            font-weight: 600;
            font-size: 0.9rem;
            padding: 0;
        }

        .item-total {
            font-weight: 700;
            font-size: 1rem;
            color: #333;
            min-width: 100px;
            text-align: right;
        }

        .btn-checkout {
            background-color: #C92127;
            color: white;
            font-weight: 700;
            width: 100%;
            padding: 12px;
            border: none;
            border-radius: 8px;
            transition: 0.3s;
            text-decoration: none;
            display: block;
            text-align: center;
            cursor: pointer;
        }
        .btn-checkout:hover { background-color: #a11b20; color: white; }
        .btn-checkout:disabled { background-color: #ccc; cursor: not-allowed; }

        /* Coupon Box Style Fahasa */
        .coupon-section {
            border: 1px solid #ddd;
            border-radius: 8px;
            padding: 15px;
            margin-bottom: 15px;
            background-color: #fff;
        }

        .coupon-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 10px;
            cursor: pointer;
        }

        .coupon-row:hover { color: #C92127; }

        .coupon-label {
            font-weight: 600;
            font-size: 0.9rem;
        }

        .coupon-value {
            font-weight: 700;
            color: #C92127;
            font-size: 0.9rem;
        }

        /* Modal Coupon */
        .coupon-card {
            border: 1px dashed #C92127;
            border-radius: 8px;
            padding: 15px;
            margin-bottom: 15px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            background-color: #fff;
            transition: 0.2s;
        }

        .coupon-card:hover { background-color: #fff5f5; }

        .coupon-info { flex: 1; }
        .coupon-code { font-weight: 700; color: #C92127; font-size: 1.1rem; }
        .coupon-desc { font-size: 0.9rem; color: #555; margin: 5px 0; }
        .coupon-expiry { font-size: 0.8rem; color: #999; }

        .btn-use-coupon {
            background-color: white;
            color: #C92127;
            border: 1px solid #C92127;
            padding: 5px 15px;
            border-radius: 20px;
            font-size: 0.85rem;
            font-weight: 600;
            transition: 0.2s;
        }

        .btn-use-coupon:hover { background-color: #C92127; color: white; }

        .empty-cart-container {
            text-align: center;
            padding: 60px 20px;
            background: white;
            border-radius: 12px;
            margin-top: 30px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.05);
        }

        .empty-cart-icon { font-size: 5rem; color: #ddd; margin-bottom: 20px; }

        .btn-shop-now {
            background-color: #C92127;
            color: white;
            padding: 10px 30px;
            border-radius: 25px;
            font-weight: 600;
            text-decoration: none;
            transition: 0.3s;
            display: inline-block;
            margin-top: 15px;
        }
        .btn-shop-now:hover { background-color: #a11b20; color: white; transform: translateY(-2px); }
    </style>
</head>
<body>
    <%- include('partials/menu') %>

    <div class="container mb-5 main-content">
        <% if (cart && cart.length > 0) { %>
            <form action="/checkout" method="POST" id="cartForm">
                <div class="row">
                    <div class="col-lg-8">
                        <div class="cart-container">
                            <div class="d-flex align-items-center border-bottom pb-3 mb-3">
                                <input type="checkbox" id="selectAll" class="item-checkbox" checked onchange="toggleAll(this)">
                                <label for="selectAll" class="fw-bold cursor-pointer">Chọn tất cả (<%= cart.length %> sản phẩm)</label>
                            </div>

                            <% cart.forEach(item => { %>
                                <div class="cart-item">
                                    <input type="checkbox" name="selected_items[]" value="<%= item.id %>"
                                           class="item-checkbox product-checkbox"
                                           data-price="<%= item.price %>"
                                           data-qty="<%= item.quantity %>"
                                           checked onchange="updateTotal()">

                                    <%
                                        let imgSrc = item.image_url;
                                        if (imgSrc && !imgSrc.startsWith('http')) imgSrc = '/images/' + imgSrc;
                                    %>
                                    <img src="<%= imgSrc || '/images/default.jpg' %>" class="item-img" onerror="this.src='https://picsum.photos/200/300'">

                                    <div class="item-info">
                                        <div class="item-name"><%= item.name %></div>
                                        <div class="item-price"><%= Number(item.price).toLocaleString('vi-VN') %> đ</div>
                                    </div>

                                    <div class="qty-control mx-3">
                                        <a href="/cart/update/<%= item.id %>?action=decrease" class="qty-btn">-</a>
                                        <input type="text" class="qty-input" value="<%= item.quantity %>" readonly>
                                        <a href="/cart/update/<%= item.id %>?action=increase" class="qty-btn">+</a>
                                    </div>

                                    <div class="text-end">
                                        <div class="item-total">
                                            <%= (item.price * item.quantity).toLocaleString('vi-VN') %> đ
                                        </div>
                                        <a href="/cart/remove/<%= item.id %>" class="text-danger text-decoration-none small mt-1 d-inline-block">
                                            <i class="fas fa-trash"></i> Xóa
                                        </a>
                                    </div>
                                </div>
                            <% }); %>
                        </div>
                    </div>

                    <div class="col-lg-4">
                        <div class="cart-container">
                            <h5 class="cart-header">Thanh toán</h5>

                            <div class="coupon-section">
                                <div class="coupon-row" data-bs-toggle="modal" data-bs-target="#couponModal" onclick="loadCoupons('product')">
                                    <span class="coupon-label"><i class="fas fa-ticket-alt me-2 text-warning"></i> Mã giảm giá</span>
                                    <span class="coupon-value" id="productDiscountText">Chọn mã ></span>
                                </div>
                            </div>

                            <div class="d-flex justify-content-between mb-2">
                                <span class="text-muted">Tạm tính:</span>
                                <span class="fw-bold" id="tempTotal">0 đ</span>
                            </div>
                            <div class="d-flex justify-content-between mb-3">
                                <span class="text-muted">Giảm giá:</span>
                                <span class="text-success" id="productDiscountAmount">-0 đ</span>
                            </div>
                            <hr>
                            <div class="d-flex justify-content-between mb-4">
                                <span class="fw-bold fs-5">Tổng cộng:</span>
                                <span class="fw-bold fs-4 text-danger" id="finalTotal">0 đ</span>
                            </div>

                            <input type="hidden" name="product_discount" id="hiddenProductDiscount" value="0">

                            <button type="submit" class="btn btn-checkout" id="btnCheckout">TIẾN HÀNH THANH TOÁN</button>
                        </div>
                    </div>
                </div>
            </form>
        <% } else { %>
            <div class="empty-cart-container">
                <i class="fas fa-shopping-cart empty-cart-icon"></i>
                <h4 class="text-muted mb-3">Giỏ hàng của bạn đang trống</h4>
                <p class="text-secondary mb-4">Hãy chọn thêm sản phẩm để mua sắm nhé!</p>
                <a href="/" class="btn-shop-now">
                    <i class="fas fa-arrow-left me-2"></i> Mua sắm ngay
                </a>
            </div>
        <% } %>
    </div>

    <!-- Modal Coupon -->
    <div class="modal fade" id="couponModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title fw-bold text-danger" id="couponModalTitle">Chọn mã giảm giá</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body bg-light" id="couponList">
                    <div class="text-center py-3">
                        <div class="spinner-border text-danger" role="status"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <footer class="bg-dark text-white text-center py-4 mt-auto">
        <div class="container">
            <p class="mb-0">&copy; 2024 Bookstore. All rights reserved.</p>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        let currentTotal = 0;
        let currentProductDiscount = 0;

        function formatMoney(amount) {
            return amount.toLocaleString('vi-VN') + ' đ';
        }

        function updateTotal() {
            let total = 0;
            const checkboxes = document.querySelectorAll('.product-checkbox:checked');

            checkboxes.forEach(cb => {
                const price = parseInt(cb.getAttribute('data-price'));
                const qty = parseInt(cb.getAttribute('data-qty'));
                total += price * qty;
            });

            currentTotal = total;
            document.getElementById('tempTotal').innerText = formatMoney(total);

            resetCoupons();
            calculateFinalTotal();

            const btnCheckout = document.getElementById('btnCheckout');
            if (checkboxes.length === 0) {
                btnCheckout.disabled = true;
                btnCheckout.innerText = "Vui lòng chọn sản phẩm";
            } else {
                btnCheckout.disabled = false;
                btnCheckout.innerText = `THANH TOÁN (${checkboxes.length})`;
            }
        }

        function calculateFinalTotal() {
            let final = currentTotal - currentProductDiscount;
            if (final < 0) final = 0;
            document.getElementById('finalTotal').innerText = formatMoney(final);
        }

        function resetCoupons() {
            currentProductDiscount = 0;
            document.getElementById('productDiscountText').innerText = "Chọn mã >";
            document.getElementById('productDiscountAmount').innerText = "-0 đ";
            document.getElementById('hiddenProductDiscount').value = 0;
        }

        function toggleAll(source) {
            const checkboxes = document.querySelectorAll('.product-checkbox');
            checkboxes.forEach(cb => cb.checked = source.checked);
            updateTotal();
        }

        function loadCoupons(type) {
            fetch('/api/coupons')
            .then(res => res.json())
            .then(data => {
                const list = document.getElementById('couponList');
                if (data.success) {
                    const coupons = data.data.product;

                    if (coupons.length > 0) {
                        let html = '';
                        coupons.forEach(c => {
                            let desc = c.discount_type === 'percent' ? `Giảm ${c.discount_value}%` : `Giảm ${c.discount_value.toLocaleString()}đ`;
                            if (c.max_discount_amount > 0) desc += ` (Tối đa ${c.max_discount_amount.toLocaleString()}đ)`;
                            let condition = c.min_order_value > 0 ? `Đơn tối thiểu ${c.min_order_value.toLocaleString()}đ` : 'Không giới hạn';

                            html += `
                                <div class="coupon-card">
                                    <div class="coupon-info">
                                        <div class="coupon-code">${c.code}</div>
                                        <div class="coupon-desc">${desc}</div>
                                        <div class="coupon-expiry text-muted small">${condition}</div>
                                    </div>
                                    <button class="btn-use-coupon" onclick="applyCoupon('${c.code}')" data-bs-dismiss="modal">Dùng ngay</button>
                                </div>
                            `;
                        });
                        list.innerHTML = html;
                    } else {
                        list.innerHTML = '<p class="text-center text-muted">Không có mã nào phù hợp.</p>';
                    }
                }
            });
        }

        function applyCoupon(code) {
            fetch('/api/coupon/check', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ code: code, totalAmount: currentTotal })
            })
            .then(res => res.json())
            .then(data => {
                const messageBox = document.createElement('div');
                messageBox.className = `alert alert-${data.success ? 'success' : 'danger'} alert-dismissible fade show`;
                messageBox.innerHTML = `${data.message} <button type="button" class="btn-close" data-bs-dismiss="alert"></button>`;
                document.querySelector('.main-content').prepend(messageBox);

                if (data.success) {
                    currentProductDiscount = data.discount;
                    document.getElementById('productDiscountText').innerText = data.code;
                    document.getElementById('productDiscountAmount').innerText = `-${formatMoney(data.discount)}`;
                    document.getElementById('hiddenProductDiscount').value = data.discount;
                    calculateFinalTotal();
                }
            })
            .catch(err => console.error(err));
        }

        document.addEventListener("DOMContentLoaded", function() {
            updateTotal();
        });
    </script>
</body>
</html>