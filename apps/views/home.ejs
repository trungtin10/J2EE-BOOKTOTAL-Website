<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <title>Trang chủ Bookstore</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body class="bg-light">
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark mb-4">
        <div class="container">
            <a class="navbar-brand fw-bold" href="/">BOOKSTORE</a>
            <div class="ms-auto">
                <a href="/admin" class="btn btn-warning btn-sm"><i class="fas fa-cog"></i> Trang Quản Trị</a>
            </div>
        </div>
    </nav>

    <div class="container">
        <h3 class="mb-4 border-bottom pb-2">Sách Mới Phát Hành</h3>
        <div class="row row-cols-1 row-cols-md-4 g-4">
            <% products.forEach(item => { %>
                <div class="col">
                    <div class="card h-100 shadow-sm">
                        <img src="/images/<%= item.image_url %>" class="card-img-top" style="height: 250px; object-fit: cover;">
                        <div class="card-body">
                            <h5 class="card-title text-truncate"><%= item.name %></h5>
                            <p class="text-muted small"><%= item.author %></p>
                            <div class="d-flex justify-content-between align-items-center mt-3">
                                <span class="text-danger fw-bold"><%= item.price.toLocaleString('vi-VN') %> đ</span>
                                <button class="btn btn-primary btn-sm">Mua ngay</button>
                            </div>
                        </div>
                    </div>
                </div>
            <% }); %>
        </div>
    </div>
</body>
</html>