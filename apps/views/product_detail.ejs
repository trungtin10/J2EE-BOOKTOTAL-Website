<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <title><%= product.name %> - Bookstore</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <!-- Link CSS riêng -->
    <link rel="stylesheet" href="/css/product-detail.css">
</head>
<body>
    <%- include('partials/menu') %>

    <!-- Toast Container -->
    <div class="toast-container">
        <div id="cartToast" class="toast align-items-center text-white bg-success border-0" role="alert" aria-live="assertive" aria-atomic="true">
            <div class="d-flex">
                <div class="toast-body p-3">
                    <i class="fas fa-check-circle fa-lg me-2"></i> <span id="toastMessage">Thêm vào giỏ hàng thành công!</span>
                </div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
            </div>
        </div>

        <div id="errorToast" class="toast align-items-center text-white bg-danger border-0" role="alert" aria-live="assertive" aria-atomic="true">
            <div class="d-flex">
                <div class="toast-body p-3">
                    <i class="fas fa-exclamation-circle fa-lg me-2"></i> <span id="errorMessage">Hết hàng!</span>
                </div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
            </div>
        </div>
    </div>

    <div class="container mt-3">
        <!-- Breadcrumb -->
        <div class="breadcrumb shadow-sm">
            <a href="/">Trang chủ</a> <span class="mx-2">/</span>
            <a href="#"><%= product.category_name || 'Sách' %></a> <span class="mx-2">/</span>
            <span class="text-muted"><%= product.name %></span>
        </div>

        <!-- Product Info -->
        <div class="product-container">
            <div class="row">
                <div class="col-md-5 text-center">
                    <%
                        let imgSrc = product.image_url;
                        if (imgSrc && !imgSrc.startsWith('http')) {
                            imgSrc = '/images/' + imgSrc;
                        }
                    %>
                    <img src="<%= imgSrc || '/images/default.jpg' %>"
                         class="product-img"
                         alt="<%= product.name %>"
                         onerror="this.src='https://picsum.photos/400/600'">
                </div>

                <div class="col-md-7">
                    <h1 class="product-title"><%= product.name %></h1>
                    <p class="product-author">
                        Tác giả: <strong class="text-dark"><%= product.author %></strong>
                        <span class="mx-3">|</span>
                        Tình trạng: <span class="text-success fw-bold"><%= product.quantity > 0 ? 'Còn hàng' : 'Hết hàng' %></span>
                    </p>

                    <div class="price-box">
                        <span class="current-price"><%= Number(product.price).toLocaleString('vi-VN') %> đ</span>
                    </div>

                    <!-- Form thêm vào giỏ hàng (Dùng AJAX) -->
                    <div class="mb-4">
                        <label class="fw-bold mb-2">Số lượng:</label>
                        <div class="input-group" style="width: 140px;">
                            <button class="btn btn-outline-secondary" type="button" onclick="decreaseQty()">-</button>
                            <input type="text" class="form-control text-center" value="1" id="qtyInput">
                            <button class="btn btn-outline-secondary" type="button" onclick="increaseQty()">+</button>
                        </div>
                    </div>

                    <div class="d-flex">
                        <button class="btn btn-add-cart" onclick="addToCart(<%= product.id %>)">
                            <i class="fas fa-cart-plus me-2"></i> Thêm vào giỏ hàng
                        </button>
                        <button class="btn btn-buy-now" onclick="buyNow(<%= product.id %>)">
                            Mua ngay
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Tabs: Mô tả & Đánh giá -->
        <div class="bg-white rounded-top-3 shadow-sm mt-4">
            <ul class="nav nav-tabs" id="productTab" role="tablist">
                <li class="nav-item" role="presentation">
                    <button class="nav-link active" id="desc-tab" data-bs-toggle="tab" data-bs-target="#desc" type="button" role="tab">Mô tả sản phẩm</button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link" id="review-tab" data-bs-toggle="tab" data-bs-target="#review" type="button" role="tab">Đánh giá khách hàng</button>
                </li>
            </ul>
        </div>

        <div class="tab-content mb-5" id="productTabContent">
            <!-- Tab Mô tả -->
            <div class="tab-pane fade show active" id="desc" role="tabpanel">
                <div class="text-muted" style="line-height: 1.8;">
                    <p><%= product.description || "Đang cập nhật nội dung..." %></p>
                </div>
            </div>

            <!-- Tab Đánh giá -->
            <div class="tab-pane fade" id="review" role="tabpanel">

                <!-- Tổng quan đánh giá -->
                <div class="rating-overview">
                    <div class="text-center">
                        <%
                            let avgRating = 0;
                            if (reviews && reviews.length > 0) {
                                let total = reviews.reduce((sum, r) => sum + r.rating, 0);
                                avgRating = (total / reviews.length).toFixed(1);
                            }
                        %>
                        <div class="rating-score"><%= avgRating %>/5</div>
                        <div class="rating-stars">
                            <i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star-half-alt"></i>
                        </div>
                        <div class="text-muted small mt-1">(<%= reviews ? reviews.length : 0 %> đánh giá)</div>
                    </div>
                    <div class="flex-grow-1" style="max-width: 400px;">
                        <div class="rating-row">
                            <span>5 sao</span>
                            <div class="progress"><div class="progress-bar" style="width: <%= reviews.length > 0 ? (reviews.filter(r => r.rating == 5).length / reviews.length * 100) : 0 %>%"></div></div>
                            <span><%= reviews.filter(r => r.rating == 5).length %></span>
                        </div>
                        <div class="rating-row">
                            <span>4 sao</span>
                            <div class="progress"><div class="progress-bar" style="width: <%= reviews.length > 0 ? (reviews.filter(r => r.rating == 4).length / reviews.length * 100) : 0 %>%"></div></div>
                            <span><%= reviews.filter(r => r.rating == 4).length %></span>
                        </div>
                        <div class="rating-row">
                            <span>3 sao</span>
                            <div class="progress"><div class="progress-bar" style="width: 5%"></div></div>
                            <span>5%</span>
                        </div>
                    </div>

                    <div class="ms-auto text-end">
                        <% if (locals.session && locals.session.user) { %>
                            <% if (canReview) { %>
                                <button class="btn btn-primary" type="button" data-bs-toggle="collapse" data-bs-target="#reviewForm">
                                    <i class="fas fa-pen me-2"></i> Viết đánh giá
                                </button>
                            <% } else { %>
                                <div class="alert alert-warning py-2 px-3 mb-0" style="font-size: 0.9rem;">
                                    <i class="fas fa-shopping-bag me-2"></i> Bạn cần mua sản phẩm này để đánh giá.
                                </div>
                            <% } %>
                        <% } else { %>
                            <p class="mb-2 text-muted small">Đăng nhập để gửi đánh giá của bạn</p>
                            <button class="btn btn-outline-danger fw-bold" data-bs-toggle="modal" data-bs-target="#loginModal">
                                <i class="fas fa-sign-in-alt me-2"></i> Đăng nhập ngay
                            </button>
                        <% } %>
                    </div>
                </div>

                <!-- Form đánh giá -->
                <div class="collapse mt-4" id="reviewForm">
                    <div class="card card-body bg-light border-0">
                        <h5 class="mb-3">Gửi đánh giá của bạn</h5>
                        <form action="/product/<%= product.id %>/review" method="POST">
                            <div class="mb-3 d-flex align-items-center">
                                <label class="fw-bold me-3">Chọn mức độ hài lòng:</label>
                                <div class="rating-input">
                                    <input type="radio" id="star5" name="rating" value="5" checked><label for="star5" title="Tuyệt vời">★</label>
                                    <input type="radio" id="star4" name="rating" value="4"><label for="star4" title="Hài lòng">★</label>
                                    <input type="radio" id="star3" name="rating" value="3"><label for="star3" title="Bình thường">★</label>
                                    <input type="radio" id="star2" name="rating" value="2"><label for="star2" title="Tệ">★</label>
                                    <input type="radio" id="star1" name="rating" value="1"><label for="star1" title="Rất tệ">★</label>
                                </div>
                            </div>
                            <div class="mb-3">
                                <textarea name="comment" class="form-control" rows="3" placeholder="Hãy chia sẻ cảm nhận của bạn về sản phẩm này..." required></textarea>
                            </div>
                            <div class="text-end">
                                <button type="submit" class="btn btn-success px-4">Gửi đánh giá</button>
                            </div>
                        </form>
                    </div>
                </div>

                <!-- Danh sách đánh giá -->
                <div class="review-list mt-4">
                    <% if (reviews && reviews.length > 0) { %>
                        <% reviews.forEach(review => { %>
                            <div class="review-item">
                                <div class="user-avatar">
                                    <%= review.full_name ? review.full_name.charAt(0).toUpperCase() : 'U' %>
                                </div>
                                <div class="review-content">
                                    <div class="review-name"><%= review.full_name || 'Người dùng ẩn danh' %></div>
                                    <div class="review-stars">
                                        <% for(let i=0; i<review.rating; i++) { %>★<% } %>
                                        <% for(let i=review.rating; i<5; i++) { %>☆<% } %>
                                    </div>
                                    <div class="review-date"><%= new Date(review.created_at).toLocaleDateString('vi-VN') %></div>
                                    <p class="mt-2 mb-0 text-secondary"><%= review.comment %></p>
                                </div>
                            </div>
                        <% }); %>
                    <% } else { %>
                        <div class="text-center py-5">
                            <img src="https://cdn-icons-png.flaticon.com/512/4076/4076432.png" width="60" class="opacity-25 mb-3">
                            <p class="text-muted">Chưa có đánh giá nào cho sản phẩm này.</p>
                        </div>
                    <% } %>
                </div>
            </div>
        </div>

        <!-- Related Products -->
        <div class="mt-5 mb-5">
            <h3 class="section-header">Sản phẩm liên quan</h3>
            <div class="row row-cols-2 row-cols-md-5 g-4">
                <% if (locals.relatedProducts) { %>
                    <% relatedProducts.slice(0, 5).forEach(item => { %>
                        <% if (item.id !== product.id) { %>
                            <div class="col">
                                <a href="/product/<%= item.id %>" class="text-decoration-none">
                                    <div class="card related-card h-100">
                                        <%
                                            let rImg = item.image_url;
                                            if (rImg && !rImg.startsWith('http')) rImg = '/images/' + rImg;
                                        %>
                                        <img src="<%= rImg || '/images/default.jpg' %>" class="related-img card-img-top" onerror="this.src='https://picsum.photos/200/300'">
                                        <div class="card-body p-2">
                                            <div class="related-title text-truncate"><%= item.name %></div>
                                            <div class="related-price mt-1"><%= Number(item.price).toLocaleString('vi-VN') %> đ</div>
                                        </div>
                                    </div>
                                </a>
                            </div>
                        <% } %>
                    <% }); %>
                <% } %>
            </div>
        </div>
    </div>

    <!-- Footer -->
    <footer class="bg-dark text-white text-center py-4 mt-5">
        <div class="container">
            <p class="mb-0">&copy; 2024 Bookstore. All rights reserved.</p>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <!-- Link JS riêng -->
    <script src="/js/product-detail.js"></script>
</body>
</html>