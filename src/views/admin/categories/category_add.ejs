<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8">
    <title>Thêm Danh Mục - Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        body {
            background-color: #f4f6f9;
            font-family: 'Segoe UI', sans-serif;
        }

        .admin-header {
            background-color: #1a1a2e;
            color: white;
            padding: 15px 0;
            margin-bottom: 30px;
        }

        .card {
            border: none;
            border-radius: 12px;
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.05);
        }
    </style>
</head>

<body>
    <div class="container-fluid">
        <div class="row">
            <%- include('../partials/menu') %>

                <main class="col-md-9 ms-sm-auto col-lg-10 px-md-4 py-4">
                    <header class="admin-header">
                        <div class="container d-flex justify-content-between align-items-center">
                            <h4 class="mb-0 fw-bold"><i class="fas fa-plus-circle me-2"></i> THÊM DANH MỤC MỚI</h4>
                            <a href="/admin/categories" class="btn btn-sm btn-outline-light"><i
                                    class="fas fa-arrow-left me-1"></i> Quay lại</a>
                        </div>
                    </header>

                    <div class="container pb-5">
                        <div class="card p-4">
                            <form action="/admin/categories/add" method="POST">

                                <div class="row mb-3">
                                    <div class="col-md-12">
                                        <label class="form-label fw-bold">Tên danh mục <span
                                                class="text-danger">*</span></label>
                                        <input type="text" name="name" class="form-control"
                                            placeholder="Nhập tên danh mục..." required>
                                    </div>
                                </div>

                                <div class="text-end mt-4">
                                    <button type="submit" class="btn btn-success fw-bold"><i class="fas fa-save"></i>
                                        Thêm Danh Mục</button>
                                </div>
                            </form>
                        </div>
                    </div>
                </main>
        </div>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>