<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <title>Quản Lý Kho - Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        body { background-color: #f4f6f9; font-family: 'Segoe UI', sans-serif; }
        .admin-header { background-color: #1a1a2e; color: white; padding: 15px 0; margin-bottom: 30px; }
        .card { border: none; border-radius: 12px; box-shadow: 0 4px 20px rgba(0,0,0,0.05); }
        .table th { background-color: #f8f9fa; font-weight: 600; }
        .product-img { width: 40px; height: 60px; object-fit: cover; border-radius: 4px; margin-right: 10px; }
        .stock-badge { padding: 5px 10px; border-radius: 20px; font-size: 0.8rem; font-weight: 600; }
        .stock-ok { background-color: #d1e7dd; color: #0f5132; }
        .stock-low { background-color: #fff3cd; color: #856404; }
        .stock-out { background-color: #f8d7da; color: #842029; }
        .filter-btn { margin-right: 5px; border-radius: 20px; }
    </style>
</head>
<body>

    <header class="admin-header">
        <div class="container d-flex justify-content-between align-items-center">
            <h4 class="mb-0 fw-bold"><i class="fas fa-warehouse me-2"></i> QUẢN LÝ KHO HÀNG</h4>
            <a href="/admin" class="btn btn-sm btn-outline-light"><i class="fas fa-home me-1"></i> Dashboard</a>
        </div>
    </header>

    <div class="container pb-5">
        <div class="card">
            <div class="card-header bg-white py-3">
                <div class="d-flex justify-content-between align-items-center">
                    <h5 class="mb-0 fw-bold">Danh sách tồn kho</h5>
                    <div>
                        <button class="btn btn-sm btn-outline-secondary filter-btn active" onclick="filterTable('all')">Tất cả</button>
                        <button class="btn btn-sm btn-outline-warning filter-btn" onclick="filterTable('low')">Sắp hết</button>
                        <button class="btn btn-sm btn-outline-danger filter-btn" onclick="filterTable('out')">Hết hàng</button>
                    </div>
                </div>
            </div>
            <div class="card-body">
                <table class="table table-hover align-middle" id="inventoryTable">
                    <thead>
                        <tr>
                            <th>Sản phẩm</th>
                            <th class="text-center">Giá bán</th>
                            <th class="text-center">Tồn kho</th>
                            <th class="text-center">Tổng giá trị</th>
                            <th class="text-center">Trạng thái</th>
                            <th class="text-end">Hành động</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (products && products.length > 0) { %>
                            <% products.forEach(p => {
                                let statusClass = 'stock-ok';
                                let statusText = 'Còn hàng';
                                let filterType = 'ok';

                                if (p.quantity === 0) {
                                    statusClass = 'stock-out';
                                    statusText = 'Hết hàng';
                                    filterType = 'out';
                                } else if (p.quantity < 10) {
                                    statusClass = 'stock-low';
                                    statusText = 'Sắp hết';
                                    filterType = 'low';
                                }
                            %>
                                <tr class="inventory-row" data-type="<%= filterType %>">
                                    <td>
                                        <div class="d-flex align-items-center">
                                            <%
                                                let imgSrc = p.image_url;
                                                if (imgSrc && !imgSrc.startsWith('http')) imgSrc = '/images/' + imgSrc;
                                            %>
                                            <img src="<%= imgSrc || '/images/default.jpg' %>" class="product-img" onerror="this.src='https://picsum.photos/40/60'">
                                            <div>
                                                <div class="fw-bold"><%= p.name %></div>
                                                <div class="small text-muted">ID: #<%= p.id %></div>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="text-center"><%= Number(p.price).toLocaleString('vi-VN') %> đ</td>
                                    <td class="text-center fw-bold" style="font-size: 1.1rem;"><%= p.quantity %></td>
                                    <td class="text-center text-muted"><%= Number(p.price * p.quantity).toLocaleString('vi-VN') %> đ</td>
                                    <td class="text-center">
                                        <span class="stock-badge <%= statusClass %>"><%= statusText %></span>
                                    </td>
                                    <td class="text-end">
                                        <button class="btn btn-sm btn-outline-secondary me-1" title="Lịch sử nhập" onclick="viewHistory('<%= p.id %>', '<%= p.name %>')">
                                            <i class="fas fa-history"></i>
                                        </button>
                                        <button class="btn btn-sm btn-primary" onclick="openImportModal('<%= p.id %>', '<%= p.name %>', <%= p.quantity %>)">
                                            <i class="fas fa-plus-circle"></i> Nhập
                                        </button>
                                    </td>
                                </tr>
                            <% }); %>
                        <% } else { %>
                            <tr><td colspan="6" class="text-center py-4 text-muted">Kho hàng trống.</td></tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Modal Nhập Hàng -->
    <div class="modal fade" id="importModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title fw-bold">Nhập hàng vào kho</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <form action="/admin/inventory/import" method="POST">
                    <div class="modal-body">
                        <input type="hidden" name="product_id" id="importProductId">

                        <div class="mb-3">
                            <label class="form-label text-muted">Sản phẩm:</label>
                            <div class="fw-bold fs-5" id="importProductName">---</div>
                        </div>

                        <div class="row">
                            <div class="col-6">
                                <label class="form-label text-muted">Tồn hiện tại:</label>
                                <div class="fw-bold text-primary" id="importCurrentStock">0</div>
                            </div>
                            <div class="col-6">
                                <label class="form-label fw-bold">Số lượng nhập thêm:</label>
                                <input type="number" name="quantity" class="form-control fw-bold" min="1" value="10" required>
                            </div>
                        </div>

                        <div class="mt-3">
                            <label class="form-label text-muted small">Ghi chú nhập hàng (Tùy chọn):</label>
                            <textarea name="note" class="form-control form-control-sm" rows="2" placeholder="VD: Nhập từ NXB Trẻ..."></textarea>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                        <button type="submit" class="btn btn-success fw-bold"><i class="fas fa-save me-2"></i> Xác nhận nhập</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Modal Lịch Sử -->
    <div class="modal fade" id="historyModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title fw-bold">Lịch sử nhập hàng: <span id="historyProductName" class="text-primary"></span></h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <table class="table table-sm table-bordered">
                        <thead>
                            <tr class="table-light">
                                <th>Ngày nhập</th>
                                <th>Số lượng</th>
                                <th>Ghi chú</th>
                            </tr>
                        </thead>
                        <tbody id="historyTableBody">
                            <!-- Data will be loaded here -->
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        function openImportModal(id, name, currentStock) {
            document.getElementById('importProductId').value = id;
            document.getElementById('importProductName').innerText = name;
            document.getElementById('importCurrentStock').innerText = currentStock;
            new bootstrap.Modal(document.getElementById('importModal')).show();
        }

        function filterTable(type) {
            const rows = document.querySelectorAll('.inventory-row');
            rows.forEach(row => {
                if (type === 'all' || row.getAttribute('data-type') === type) {
                    row.style.display = '';
                } else {
                    row.style.display = 'none';
                }
            });
        }

        function viewHistory(id, name) {
            document.getElementById('historyProductName').innerText = name;
            const tbody = document.getElementById('historyTableBody');
            tbody.innerHTML = '<tr><td colspan="3" class="text-center">Đang tải...</td></tr>';

            new bootstrap.Modal(document.getElementById('historyModal')).show();

            fetch(`/admin/inventory/logs/${id}`)
                .then(res => res.json())
                .then(data => {
                    if (data.success && data.data.length > 0) {
                        let html = '';
                        data.data.forEach(log => {
                            html += `
                                <tr>
                                    <td>${new Date(log.created_at).toLocaleString('vi-VN')}</td>
                                    <td class="fw-bold text-success">+${log.quantity}</td>
                                    <td>${log.note || '---'}</td>
                                </tr>
                            `;
                        });
                        tbody.innerHTML = html;
                    } else {
                        tbody.innerHTML = '<tr><td colspan="3" class="text-center text-muted">Chưa có lịch sử nhập hàng.</td></tr>';
                    }
                })
                .catch(err => {
                    tbody.innerHTML = '<tr><td colspan="3" class="text-center text-danger">Lỗi tải dữ liệu.</td></tr>';
                });
        }
    </script>
</body>
</html>