<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8">
    <title>Cập Nhật Sách - Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        body {
            background-color: #f4f6f9;
            font-family: 'Segoe UI', sans-serif;
        }

        .card {
            border: none;
            border-radius: 12px;
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.05);
        }

        .card-header {
            background: white;
            border-bottom: 1px solid #eee;
            padding: 20px 30px;
            border-radius: 12px 12px 0 0 !important;
        }

        .form-label {
            font-weight: 600;
            color: #555;
            font-size: 0.9rem;
        }

        .form-control,
        .form-select {
            padding: 10px 15px;
            border-radius: 8px;
            border: 1px solid #dee2e6;
        }

        .form-control:focus {
            border-color: #C92127;
            box-shadow: 0 0 0 3px rgba(201, 33, 39, 0.1);
        }

        .btn-save {
            background-color: #C92127;
            color: white;
            font-weight: 600;
            padding: 10px 30px;
            border-radius: 8px;
            border: none;
            transition: 0.3s;
        }

        .btn-save:hover {
            background-color: #a11b20;
            transform: translateY(-2px);
        }

        .upload-box {
            border: 2px dashed #ddd;
            border-radius: 12px;
            padding: 30px;
            text-align: center;
            cursor: pointer;
            transition: 0.3s;
            background: #fff;
        }

        .upload-box:hover {
            border-color: #C92127;
            background: #fff5f5;
        }

        #previewImg {
            max-height: 200px;
            border-radius: 8px;
            display: none;
            margin: 0 auto;
            box-shadow: 0 4px 10px rgba(0, 0, 0, 0.1);
        }
    </style>
</head>

<body>
    <div class="container py-5">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h3 class="fw-bold text-dark"><i class="fas fa-edit text-primary me-2"></i> Cập Nhật Sách</h3>
            <a href="/admin/products" class="btn btn-outline-secondary"><i class="fas fa-arrow-left me-2"></i> Quay
                lại</a>
        </div>

        <form action="/admin/products/edit/<%= product.id %>" method="POST" enctype="multipart/form-data">
            <div class="row">
                <div class="col-lg-8">
                    <div class="card mb-4">
                        <div class="card-header">
                            <h5 class="mb-0">Thông tin chung</h5>
                        </div>
                        <div class="card-body p-4">
                            <div class="mb-3">
                                <label class="form-label">Tên sách <span class="text-danger">*</span></label>
                                <input type="text" name="name" class="form-control" value="<%= product.name %>"
                                    required>
                            </div>

                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label class="form-label">Tác giả <span class="text-danger">*</span></label>
                                    <input type="text" name="author_name" class="form-control"
                                        value="<%= product.author_name %>" required>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label class="form-label">Danh mục <span class="text-danger">*</span></label>
                                    <select name="category_id" class="form-select" required>
                                        <option value="">-- Chọn Danh mục --</option>
                                        <% if (locals.categories) { %>
                                            <% categories.forEach(c=> { %>
                                                <option value="<%= c.id %>" <%=product.category_id===c.id ? 'selected'
                                                    : '' %>>
                                                    <%= c.name %>
                                                </option>
                                                <% }); %>
                                                    <% } %>
                                    </select>
                                </div>
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Mô tả sản phẩm</label>
                                <textarea name="description" class="form-control" rows="10"
                                    placeholder="Nhập mô tả sản phẩm (giữ nguyên khoảng cách và xuống dòng)"
                                    style="white-space: pre-wrap;"><%= product.description %></textarea>
                            </div>
                        </div>
                    </div>

                    <div class="card">
                        <div class="card-header">
                            <h5 class="mb-0">Chi tiết xuất bản</h5>
                        </div>
                        <div class="card-body p-4">
                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label class="form-label">Nhà cung cấp</label>
                                    <input type="text" name="supplier_name" class="form-control"
                                        value="<%= product.supplier_name %>">
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label class="form-label">Nhà xuất bản</label>
                                    <input type="text" name="publisher_name" class="form-control"
                                        value="<%= product.publisher_name %>">
                                </div>
                                <div class="col-md-4 mb-3">
                                    <label class="form-label">Năm xuất bản</label>
                                    <input type="number" name="publication_year" class="form-control"
                                        value="<%= product.publication_year %>" min="1900" max="2099">
                                </div>
                                <div class="col-md-4 mb-3">
                                    <label class="form-label">Số trang</label>
                                    <input type="number" name="pages" class="form-control" value="<%= product.pages %>"
                                        min="1">
                                </div>
                                <div class="col-md-4 mb-3">
                                    <label class="form-label">Loại bìa</label>
                                    <select name="cover_type" class="form-select">
                                        <option value="Bìa mềm" <%=product.cover_type==='Bìa mềm' ? 'selected' : '' %>
                                            >Bìa mềm</option>
                                        <option value="Bìa cứng" <%=product.cover_type==='Bìa cứng' ? 'selected' : '' %>
                                            >Bìa cứng</option>
                                    </select>
                                </div>
                                <!-- THÊM 2 TRƯỜNG MỚI -->
                                <div class="col-md-6 mb-3">
                                    <label class="form-label">Ngôn ngữ</label>
                                    <input type="text" name="language" class="form-control"
                                        value="<%= product.language %>">
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label class="form-label">Kích thước bao bì</label>
                                    <input type="text" name="dimensions" class="form-control"
                                        value="<%= product.dimensions %>">
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-lg-4">
                    <div class="card mb-4">
                        <div class="card-header">
                            <h5 class="mb-0">Giá & Kho hàng</h5>
                        </div>
                        <div class="card-body p-4">
                            <div class="mb-3">
                                <label class="form-label">Giá bán (VNĐ) <span class="text-danger">*</span></label>
                                <div class="input-group">
                                    <input type="number" name="price" class="form-control fw-bold text-danger"
                                        value="<%= product.price %>" required min="0">
                                    <span class="input-group-text">₫</span>
                                </div>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Số lượng tồn <span class="text-danger">*</span></label>
                                <input type="number" name="quantity" class="form-control"
                                    value="<%= product.quantity %>" required min="0">
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Trạng thái hiển thị</label>
                                <select name="is_hidden" class="form-select">
                                    <option value="0" <%=product.is_hidden==0 ? 'selected' : '' %>>Hiển thị (Khách hàng
                                        có thể thấy)</option>
                                    <option value="1" <%=product.is_hidden==1 ? 'selected' : '' %>>Đang ẩn (Tạm khóa/Hết
                                        hàng)</option>
                                </select>
                            </div>
                        </div>
                    </div>

                    <div class="card">
                        <div class="card-header">
                            <h5 class="mb-0">Hình ảnh</h5>
                        </div>
                        <div class="card-body p-4 text-center">
                            <div class="upload-box" onclick="document.getElementById('fileInput').click()">
                                <% let imgSrc=product.image_url; if (imgSrc && !imgSrc.startsWith('http'))
                                    imgSrc='/images/' + imgSrc; %>
                                    <img id="previewImg" src="<%= imgSrc || '#' %>" alt="Preview"
                                        style="<%= imgSrc ? 'display:block' : 'display:none' %>">

                                    <div id="uploadPlaceholder"
                                        style="<%= imgSrc ? 'display:none' : 'display:block' %>">
                                        <i class="fas fa-cloud-upload-alt fa-3x text-secondary mb-2"></i>
                                        <p class="text-muted small mb-0">Click để thay đổi ảnh</p>
                                    </div>
                            </div>
                            <input type="file" name="image" id="fileInput" class="d-none" accept="image/*"
                                onchange="previewFile()">
                            <input type="hidden" name="old_image" value="<%= product.image_url %>">
                        </div>
                    </div>

                    <div class="mt-4">
                        <button type="submit" class="btn btn-save w-100 py-3">
                            <i class="fas fa-save me-2"></i> CẬP NHẬT
                        </button>
                    </div>
                </div>
            </div>
        </form>
    </div>

    <script>
        function previewFile() {
            const preview = document.getElementById('previewImg');
            const placeholder = document.getElementById('uploadPlaceholder');
            const file = document.getElementById('fileInput').files[0];
            const reader = new FileReader();

            reader.onloadend = function () {
                preview.src = reader.result;
                preview.style.display = 'block';
                placeholder.style.display = 'none';
            }

            if (file) reader.readAsDataURL(file);
        }

        document.addEventListener("DOMContentLoaded", function () {
            const preview = document.getElementById('previewImg');
            const placeholder = document.getElementById('uploadPlaceholder');

            if (preview.src && !preview.src.endsWith('#')) {
                preview.style.display = 'block';
                placeholder.style.display = 'none';
            } else {
                preview.style.display = 'none';
                placeholder.style.display = 'block';
            }
        });
    </script>
    });
    </script>
</body>

</html>