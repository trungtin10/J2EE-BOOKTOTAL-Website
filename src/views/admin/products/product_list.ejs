<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <title>Quản Lý Sản Phẩm - Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        body { background-color: #f4f6f9; font-family: 'Segoe UI', sans-serif; }
        .admin-header { background-color: #1a1a2e; color: white; padding: 15px 0; margin-bottom: 30px; }
        .card { border: none; border-radius: 12px; box-shadow: 0 4px 20px rgba(0,0,0,0.05); }
        .table th { background-color: #f8f9fa; font-weight: 600; }
        .product-img { width: 50px; height: 70px; object-fit: cover; border-radius: 4px; }
    </style>
</head>
<body>

    <header class="admin-header">
        <div class="container d-flex justify-content-between align-items-center">
            <h4 class="mb-0 fw-bold"><i class="fas fa-book me-2"></i> QUẢN LÝ SẢN PHẨM</h4>
            <div>
                <a href="/admin" class="btn btn-sm btn-outline-light me-2"><i class="fas fa-home me-1"></i> Dashboard</a>
                <a href="/admin/products/add" class="btn btn-sm btn-warning fw-bold"><i class="fas fa-plus me-1"></i> Thêm mới</a>
            </div>
        </div>
    </header>

    <div class="container pb-5">
        <div class="card">
            <div class="card-body">
                <table class="table table-hover align-middle">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Hình ảnh</th>
                            <th>Tên sách</th>
                            <th>Tác giả</th>
                            <th>Giá bán</th>
                            <th>Tồn kho</th>
                            <th>Đã bán</th>
                            <th>Hành động</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (products && products.length > 0) { %>
                            <% products.forEach(p => { %>
                                <tr>
                                    <td>#<%= p.id %></td>
                                    <td>
                                        <%
                                            let imgSrc = p.image_url;
                                            if (imgSrc && !imgSrc.startsWith('http')) imgSrc = '/images/' + imgSrc;
                                        %>
                                        <img src="<%= imgSrc || '/images/default.jpg' %>" class="product-img" onerror="this.src='https://picsum.photos/50/70'">
                                    </td>
                                    <td style="max-width: 200px;" class="text-truncate" title="<%= p.name %>"><%= p.name %></td>
                                    <td style="max-width: 150px;" class="text-truncate" title="<%= p.author_name %>"><%= p.author_name || '---' %></td>
                                    <td class="fw-bold text-danger"><%= Number(p.price).toLocaleString('vi-VN') %> đ</td>
                                    <td>
                                        <% if (p.quantity < 10) { %>
                                            <span class="text-danger fw-bold"><%= p.quantity %></span>
                                        <% } else { %>
                                            <span class="text-success fw-bold"><%= p.quantity %></span>
                                        <% } %>
                                    </td>
                                    <td><%= p.sold_count %></td>
                                    <td>
                                        <a href="/admin/products/detail/<%= p.id %>" class="btn btn-sm btn-info text-white me-1" title="Xem chi tiết"><i class="fas fa-eye"></i></a>
                                        <a href="/admin/products/edit/<%= p.id %>" class="btn btn-sm btn-primary me-1" title="Sửa"><i class="fas fa-edit"></i></a>

                                        <!-- Nút Xóa dùng Modal -->
                                        <button class="btn btn-sm btn-danger" title="Xóa" onclick="showConfirmModal('/admin/products/delete/<%= p.id %>', 'Bạn có chắc chắn muốn xóa sản phẩm này?')">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </td>
                                </tr>
                            <% }); %>
                        <% } else { %>
                            <tr>
                                <td colspan="8" class="text-center py-4 text-muted">Chưa có sản phẩm nào.</td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Include Modal -->
    <%- include('../partials/confirm_modal') %>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>