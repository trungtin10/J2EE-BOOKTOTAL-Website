<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <title>Quản Lý Đánh Giá - Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        body { background-color: #f4f6f9; font-family: 'Segoe UI', sans-serif; }
        .admin-header { background-color: #1a1a2e; color: white; padding: 15px 0; margin-bottom: 30px; }
        .card { border: none; border-radius: 12px; box-shadow: 0 4px 20px rgba(0,0,0,0.05); }
        .table th { background-color: #f8f9fa; font-weight: 600; }
        .status-badge { padding: 5px 10px; border-radius: 20px; font-size: 0.8rem; font-weight: 600; }
        .status-pending { background-color: #fff3cd; color: #ffc107; }
        .status-approved { background-color: #d1e7dd; color: #198754; }
        .admin-reply { font-size: 0.85rem; color: #666; background: #f8f9fa; padding: 8px; border-radius: 6px; margin-top: 5px; border-left: 3px solid #1a1a2e; }
    </style>
</head>
<body>

    <header class="admin-header">
        <div class="container d-flex justify-content-between align-items-center">
            <h4 class="mb-0 fw-bold"><i class="fas fa-star me-2"></i> QUẢN LÝ ĐÁNH GIÁ</h4>
            <a href="/admin" class="btn btn-sm btn-outline-light"><i class="fas fa-home me-1"></i> Dashboard</a>
        </div>
    </header>

    <div class="container pb-5">
        <div class="card">
            <div class="card-body">
                <table class="table table-hover align-middle">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Sản phẩm</th>
                            <th>Người dùng</th>
                            <th>Đánh giá</th>
                            <th>Nội dung</th>
                            <th>Ngày tạo</th>
                            <th>Trạng thái</th>
                            <th>Hành động</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (reviews && reviews.length > 0) { %>
                            <% reviews.forEach(r => { %>
                                <tr>
                                    <td>#<%= r.id %></td>
                                    <td style="max-width: 200px;" class="text-truncate" title="<%= r.product_name %>"><%= r.product_name %></td>
                                    <td><%= r.username %></td>
                                    <td class="text-warning fw-bold"><%= r.rating %> ★</td>
                                    <td style="max-width: 350px;">
                                        <div class="text-truncate" title="<%= r.comment %>"><%= r.comment %></div>
                                        <% if (r.admin_reply) { %>
                                            <div class="admin-reply">
                                                <strong>Admin:</strong> <%= r.admin_reply %>
                                            </div>
                                        <% } %>
                                    </td>
                                    <td><%= new Date(r.created_at).toLocaleDateString('vi-VN') %></td>
                                    <td>
                                        <% if (r.status === 'APPROVED') { %>
                                            <span class="status-badge status-approved">Đã duyệt</span>
                                        <% } else { %>
                                            <span class="status-badge status-pending">Chờ duyệt</span>
                                        <% } %>
                                    </td>
                                    <td>
                                        <div class="btn-group">
                                            <% if (r.status !== 'APPROVED') { %>
                                                <a href="/admin/reviews/approve/<%= r.id %>" class="btn btn-sm btn-success" title="Duyệt">
                                                    <i class="fas fa-check"></i>
                                                </a>
                                            <% } %>

                                            <!-- Nút Trả lời / Sửa trả lời -->
                                            <button class="btn btn-sm btn-primary" title="Trả lời" onclick="openReplyModal('<%= r.id %>', '<%= r.username %>', `<%= r.admin_reply || '' %>`)">
                                                <i class="fas fa-reply"></i>
                                            </button>

                                            <!-- Nút Xóa trả lời -->
                                            <% if (r.admin_reply) { %>
                                                <a href="/admin/reviews/reply/delete/<%= r.id %>" class="btn btn-sm btn-secondary" title="Xóa trả lời" onclick="return confirm('Xóa câu trả lời này?')">
                                                    <i class="fas fa-eraser"></i>
                                                </a>
                                            <% } %>

                                            <a href="/admin/reviews/delete/<%= r.id %>" class="btn btn-sm btn-danger" title="Xóa" onclick="return confirm('Xóa đánh giá này?')">
                                                <i class="fas fa-trash"></i>
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            <% }); %>
                        <% } else { %>
                            <tr>
                                <td colspan="8" class="text-center py-4 text-muted">Chưa có đánh giá nào.</td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Modal Trả lời / Sửa -->
    <div class="modal fade" id="replyModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Trả lời đánh giá của <span id="replyUsername" class="fw-bold text-primary"></span></h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <form action="/admin/reviews/reply" method="POST">
                    <div class="modal-body">
                        <input type="hidden" name="review_id" id="replyReviewId">
                        <div class="mb-3">
                            <label class="form-label">Nội dung trả lời:</label>
                            <textarea name="reply_content" id="replyContent" class="form-control" rows="4" required placeholder="Nhập câu trả lời của Admin..."></textarea>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                        <button type="submit" class="btn btn-primary">Gửi trả lời</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        function openReplyModal(id, username, currentReply) {
            document.getElementById('replyReviewId').value = id;
            document.getElementById('replyUsername').innerText = username;
            document.getElementById('replyContent').value = currentReply; // Gán nội dung cũ vào textarea
            const modal = new bootstrap.Modal(document.getElementById('replyModal'));
            modal.show();
        }
    </script>
</body>
</html>