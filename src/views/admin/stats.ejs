<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8">
    <title>Thống Kê & Báo Cáo - Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        body {
            background-color: #f4f6f9;
            font-family: 'Segoe UI', sans-serif;
        }

        .admin-header {
            background-color: #1a1a2e;
            color: white;
            padding: 15px 0;
            margin-bottom: 30px;
        }

        .card {
            border: none;
            border-radius: .75rem;
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.05);
            margin-bottom: 2rem;
        }

        .card-header {
            background-color: #fff;
            border-bottom: none;
            padding: 1.25rem 1.5rem;
            font-weight: 600;
        }

        .stat-card {
            position: relative;
            overflow: hidden;
            color: #fff;
            border-radius: .75rem;
        }

        .stat-card .icon {
            position: absolute;
            top: 50%;
            right: 20px;
            transform: translateY(-50%);
            font-size: 4rem;
            opacity: 0.2;
        }

        .stat-card h3 {
            font-size: 2.5rem;
            font-weight: 700;
        }

        .bg-success-light {
            background-color: #28a745;
        }

        .bg-info-light {
            background-color: #17a2b8;
        }

        .bg-warning-light {
            background-color: #ffc107;
            color: #333 !important;
        }

        .bg-primary-light {
            background-color: #007bff;
        }

        .bg-danger-light {
            background-color: #dc3545;
        }

        .order-status-box {
            padding: 1rem;
            border-radius: .5rem;
            color: #fff;
            text-align: center;
        }

        .status-badge {
            display: inline-block;
            padding: .35em .65em;
            font-size: .75em;
            font-weight: 700;
            line-height: 1;
            color: #fff;
            text-align: center;
            white-space: nowrap;
            vertical-align: baseline;
            border-radius: .25rem;
        }

        .status-COMPLETED {
            background-color: #28a745;
        }

        .status-PENDING {
            background-color: #ffc107;
            color: #212529;
        }

        .status-CONFIRMED {
            background-color: #17a2b8;
        }

        .status-SHIPPING {
            background-color: #007bff;
        }

        .status-CANCELLED {
            background-color: #dc3545;
        }

        .payment-badge {
            padding: 5px 12px;
            border-radius: 20px;
            font-size: 0.8rem;
            font-weight: 600;
        }

        .payment-badge.PAID {
            background-color: #d1e7dd;
            color: #0f5132;
        }

        .payment-badge.UNPAID {
            background-color: #f8d7da;
            color: #842029;
        }
    </style>
</head>

<body>
    <div class="container-fluid">
        <div class="row">
            <!-- Sidebar -->
            <%- include('partials/menu') %>

                <!-- Main Content -->
                <main class="col-md-9 ms-sm-auto col-lg-10 px-md-4 py-4">
                    <div
                        class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
                        <h1 class="h2"><i class="fas fa-chart-pie me-2"></i> THỐNG KÊ & BÁO CÁO</h1>
                        <%- include('partials/account_dropdown') %>
                    </div>

                    <!-- Tổng quan Doanh thu và Đơn hàng -->
                    <div class="row">
                        <div class="col-lg-6 mb-4">
                            <div class="stat-card bg-success-light p-4 h-100">
                                <div class="icon"><i class="fas fa-dollar-sign"></i></div>
                                <p class="mb-2 fs-5">Tổng Doanh Thu (Đã Hoàn Thành)</p>
                                <h3>
                                    <%= totalRevenue.toLocaleString('vi-VN') %> đ
                                </h3>
                            </div>
                        </div>
                        <div class="col-lg-6 mb-4">
                            <div class="stat-card bg-info-light p-4 h-100">
                                <div class="icon"><i class="fas fa-shopping-cart"></i></div>
                                <p class="mb-2 fs-5">Tổng Số Đơn Hàng</p>
                                <h3>
                                    <%= totalOrders %>
                                </h3>
                            </div>
                        </div>
                    </div>

                    <!-- Tình hình đơn hàng -->
                    <div class="card">
                        <div class="card-header">
                            <h5 class="card-title fw-bold mb-0">Tình Hình Đơn Hàng</h5>
                        </div>
                        <div class="card-body">
                            <div class="row">
                                <div class="col">
                                    <div class="order-status-box bg-warning-light"><strong>Chờ xác nhận</strong><br>
                                        <%= orderStats.PENDING %>
                                    </div>
                                </div>
                                <div class="col">
                                    <div class="order-status-box bg-primary-light"><strong>Đã xác nhận</strong><br>
                                        <%= orderStats.CONFIRMED %>
                                    </div>
                                </div>
                                <div class="col">
                                    <div class="order-status-box bg-info-light"><strong>Đang giao</strong><br>
                                        <%= orderStats.SHIPPING %>
                                    </div>
                                </div>
                                <div class="col">
                                    <div class="order-status-box bg-success-light"><strong>Hoàn thành</strong><br>
                                        <%= orderStats.COMPLETED %>
                                    </div>
                                </div>
                                <div class="col">
                                    <div class="order-status-box bg-danger-light"><strong>Đã hủy</strong><br>
                                        <%= orderStats.CANCELLED %>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Biểu đồ doanh thu -->
                    <div class="card">
                        <div class="card-header">
                            <h5 class="card-title fw-bold mb-0">Doanh Thu 7 Ngày Gần Nhất (Đơn Hoàn Thành)</h5>
                        </div>
                        <div class="card-body">
                            <% if (data && data.length> 0) { %>
                                <canvas id="revenueChart"></canvas>
                                <% } else { %>
                                    <p class="text-center text-muted py-5">Chưa có dữ liệu doanh thu để vẽ biểu đồ.</p>
                                    <% } %>
                        </div>
                    </div>

                    <!-- Chi tiết đơn hàng gần đây -->
                    <div class="card">
                        <div class="card-header">
                            <h5 class="card-title fw-bold mb-0">Chi Tiết Đơn Hàng Gần Đây</h5>
                        </div>
                        <div class="card-body">
                            <div class="table-responsive">
                                <table class="table table-hover align-middle">
                                    <thead>
                                        <tr>
                                            <th>Mã ĐH</th>
                                            <th>Khách Hàng</th>
                                            <th>Ngày Đặt</th>
                                            <th>Tổng Tiền</th>
                                            <th>Trạng Thái</th>
                                            <th>Hành Động</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <% if (recentOrders && recentOrders.length> 0) { %>
                                            <% const statusMap={ 'PENDING' : 'Chờ xác nhận' , 'CONFIRMED'
                                                : 'Đã xác nhận' , 'PROCESSING' : 'Đang xử lý' , 'SHIPPED' : 'Đã giao VC'
                                                , 'DELIVERING' : 'Đang giao hàng' , 'COMPLETED' : 'Đã giao'
                                                , 'CANCELLED' : 'Đã hủy' }; %>
                                                <% recentOrders.forEach(order=> { %>
                                                    <% const statusText=statusMap[order.status] || order.status; %>
                                                        <tr>
                                                            <td>#<%= order.id %>
                                                            </td>
                                                            <td>
                                                                <%= order.full_name || 'Khách vãng lai' %>
                                                            </td>
                                                            <td>
                                                                <%= new
                                                                    Date(order.order_date).toLocaleDateString('vi-VN')
                                                                    %>
                                                            </td>
                                                            <td>
                                                                <%= order.final_total.toLocaleString('vi-VN') %> đ
                                                            </td>
                                                            <td><span class="status-badge status-<%= order.status %>">
                                                                    <%= statusText %>
                                                                </span></td>
                                                            <td>
                                                                <button class="btn btn-sm btn-outline-info"
                                                                    onclick="showOrderDetail('<%= order.id %>')"
                                                                    title="Xem chi tiết">
                                                                    <i class="fas fa-eye"></i> Xem chi tiết
                                                                </button>
                                                            </td>
                                                        </tr>
                                                        <% }) %>
                                                            <% } else { %>
                                                                <tr>
                                                                    <td colspan="6" class="text-center text-muted py-4">
                                                                        Chưa có đơn hàng nào.</td>
                                                                </tr>
                                                                <% } %>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>

                </main>
        </div>
    </div>

    <!-- Modal Chi Tiết Đơn Hàng (Copy từ order_list.ejs) -->
    <div class="modal fade" id="orderDetailModal" tabindex="-1">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title fw-bold">Chi tiết đơn hàng <span id="modalOrderId"
                            class="text-primary"></span></h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body" id="modalOrderContent">
                    <div class="text-center py-5">
                        <div class="spinner-border"></div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Đóng</button>
                    <button type="button" class="btn btn-primary" onclick="printOrderFromModal()"><i
                            class="fas fa-print me-2"></i> In đơn hàng</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Inject data correctly avoiding unescaped EJS formatter corruption -->
    <div id="statsChartDataContainer" data-labels="<%= JSON.stringify(labels || []) %>"
        data-values="<%= JSON.stringify(data || []) %>" style="display: none;"></div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        const statsChartDataContainer = document.getElementById('statsChartDataContainer');
        const labels = JSON.parse(statsChartDataContainer.dataset.labels);
        // Chuyển string '535000' sang number
        const data = JSON.parse(statsChartDataContainer.dataset.values).map(Number);

        if (data && data.length > 0) {
            const ctx = document.getElementById('revenueChart').getContext('2d');
            new Chart(ctx, {
                type: 'bar', // Cập nhật sang bar chart cho dễ nhìn hoặc giữ line
                data: {
                    labels: labels,
                    datasets: [{
                        label: 'Doanh thu (VNĐ)',
                        data: data,
                        backgroundColor: 'rgba(40, 167, 69, 0.6)',
                        borderColor: '#28a745',
                        borderWidth: 1
                    }]
                },
                options: {
                    responsive: true,
                    scales: {
                        y: {
                            beginAtZero: true,
                            ticks: { callback: value => value.toLocaleString('vi-VN') + ' đ' }
                        }
                    },
                    plugins: {
                        tooltip: {
                            callbacks: {
                                label: context => context.parsed.y.toLocaleString('vi-VN') + ' đ'
                            }
                        }
                    }
                }
            });
        }

        // Logic Modal Chi Tiết (Giống order_list.ejs)
        let currentOrderIdForModal = null;

        function showOrderDetail(orderId) {
            currentOrderIdForModal = orderId;
            const modal = new bootstrap.Modal(document.getElementById('orderDetailModal'));
            const modalTitle = document.getElementById('modalOrderId');
            const modalContent = document.getElementById('modalOrderContent');

            modalTitle.innerText = '#' + orderId;
            modalContent.innerHTML = '<div class="text-center py-5"><div class="spinner-border"></div></div>';
            modal.show();

            fetch(`/admin/orders/detail/${orderId}`)
                .then(res => res.json())
                .then(data => {
                    if (data.success) {
                        const order = data.data;
                        let itemsHtml = '';
                        order.items.forEach(item => {
                            itemsHtml += `
                            <div class="d-flex align-items-center mb-3 border-bottom pb-2">
                                <img src="/images/${item.image_url || 'default.jpg'}" width="60" class="me-3 rounded">
                                <div class="flex-grow-1">
                                    <div class="fw-bold">${item.name}</div>
                                    <div class="text-muted small">Số lượng: ${item.quantity}</div>
                                </div>
                                <div class="fw-bold">${Number(item.price_at_purchase).toLocaleString('vi-VN')} đ</div>
                            </div>`;
                        });

                        const statusMap = {
                            'PENDING': 'Chờ xác nhận',
                            'CONFIRMED': 'Đã xác nhận',
                            'PROCESSING': 'Đang xử lý',
                            'SHIPPED': 'Đã giao VC',
                            'DELIVERING': 'Đang giao hàng',
                            'COMPLETED': 'Đã giao',
                            'CANCELLED': 'Đã hủy'
                        };
                        const statusText = statusMap[order.status] || order.status;
                        const statusClass = `status-${order.status}`;

                        const paymentText = order.payment_status === 'PAID' ? 'Đã thanh toán' : 'Chưa thanh toán';
                        const paymentClass = order.payment_status === 'PAID' ? 'PAID' : 'UNPAID';

                        // Parsing shipping address
                        let parsedName = order.full_name || 'Khách vãng lai';
                        let parsedPhone = order.phone || 'Chưa có SĐT';
                        let cityDistrict = '';
                        let specificAddress = '';
                        let orderNote = '';

                        if (order.shipping_address) {
                            let rawAddress = order.shipping_address;
                            let noteMatch = rawAddress.match(/\((.*?)\)$/);
                            if (noteMatch) {
                                orderNote = noteMatch[1];
                                rawAddress = rawAddress.replace(/\s*\(.*?\)$/, '');
                            }
                            let parts = rawAddress.split(',').map(p => p.trim());
                            if (parts.length >= 5) {
                                let province = parts.pop();
                                let district = parts.pop();
                                let ward = parts.pop();
                                cityDistrict = `${ward}, ${district}, ${province}`;

                                parsedName = parts[0] || parsedName;
                                parsedPhone = parts[1] || parsedPhone;
                                specificAddress = parts.slice(2).join(', ');
                            } else {
                                specificAddress = rawAddress;
                            }
                        }

                        const html = `
                        <div id="printableArea">
                            <div class="row mb-4">
                                <div class="col-6">
                                    <h5 class="fw-bold">Thông tin khách hàng</h5>
                                    <p class="mb-1"><strong>Họ tên:</strong> ${parsedName}</p>
                                    <p class="mb-1"><strong>SĐT:</strong> ${parsedPhone}</p>
                                    <div class="mb-2 mt-2">
                                        <strong>Khu vực giao:</strong><br>
                                        <span class="text-muted">${cityDistrict || 'Không rõ'}</span>
                                    </div>
                                    <div class="mb-1">
                                        <strong>Địa chỉ cụ thể:</strong><br>
                                        <span class="text-muted">${specificAddress || order.shipping_address}</span>
                                    </div>
                                    ${orderNote ? `<div class="mb-1 text-danger"><strong>Ghi chú:</strong> ${orderNote}</div>` : ''}
                                </div>
                                <div class="col-6 text-end">
                                    <h5 class="fw-bold">Thông tin đơn hàng</h5>
                                    <p class="mb-1"><strong>Ngày đặt:</strong> ${new Date(order.order_date).toLocaleString('vi-VN')}</p>
                                    <p class="mb-1"><strong>Phương thức:</strong> ${order.payment_method || 'COD'}</p>
                                    <p class="mb-1"><strong>Trạng thái:</strong> <span class="fw-bold ${statusClass}">${statusText}</span></p>
                                    <p class="mb-1"><strong>Thanh toán:</strong> <span class="fw-bold payment-badge ${paymentClass}">${paymentText}</span></p>
                                </div>
                            </div>

                            <h5 class="fw-bold mt-4 mb-3">Danh sách sản phẩm</h5>
                            ${itemsHtml}

                            <div class="row mt-4">
                                <div class="col-6"></div>
                                <div class="col-6 text-end">
                                    <p class="mb-1"><strong>Tạm tính:</strong> ${Number(order.total_money).toLocaleString('vi-VN')} đ</p>
                                    <p class="mb-1"><strong>Phí vận chuyển:</strong> ${Number(order.shipping_fee).toLocaleString('vi-VN')} đ</p>
                                    <p class="mb-1"><strong>Giảm giá:</strong> -${Number(order.discount_amount).toLocaleString('vi-VN')} đ</p>
                                    <h4 class="fw-bold text-danger mt-2">Tổng cộng: ${Number(order.final_total).toLocaleString('vi-VN')} đ</h4>
                                </div>
                            </div>
                        </div>`;
                        modalContent.innerHTML = html;
                    } else {
                        modalContent.innerHTML = `<p class="text-danger text-center p-5">${data.message || 'Không thể tải dữ liệu.'}</p>`;
                    }
                })
                .catch(err => {
                    modalContent.innerHTML = `<p class="text-danger text-center p-5">Lỗi kết nối đến server.</p>`;
                });
        }

        function printOrderFromModal() {
            const printContent = document.getElementById('printableArea').innerHTML;

            const printWindow = window.open('', '', 'height=600,width=800');
            printWindow.document.write('<html><head><title>In Hóa Đơn</title>');
            printWindow.document.write('<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">');
            printWindow.document.write('<style>body{padding: 20px; font-family: "Segoe UI", sans-serif;} .dropdown { display: none; } /* Hide dropdowns in print */</style>');
            printWindow.document.write('</head><body>');
            printWindow.document.write(printContent);
            printWindow.document.write('</body></html>');
            printWindow.document.close();
            printWindow.focus();
            setTimeout(() => { printWindow.print(); }, 500);
        }
    </script>
</body>

</html>