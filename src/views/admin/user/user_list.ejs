<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <title>Quản Lý Người Dùng - Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        body { background-color: #f4f6f9; font-family: 'Segoe UI', sans-serif; }
        .admin-header { background-color: #1a1a2e; color: white; padding: 15px 0; margin-bottom: 30px; }
        .card { border: none; border-radius: 12px; box-shadow: 0 4px 20px rgba(0,0,0,0.05); }
        .table th { background-color: #f8f9fa; font-weight: 600; }
        .role-badge { padding: 5px 10px; border-radius: 20px; font-size: 0.8rem; font-weight: 600; text-transform: uppercase; }
        .role-admin { background-color: #cff4fc; color: #055160; }
        .role-user { background-color: #d1e7dd; color: #0f5132; }
        .password-cell { font-family: monospace; color: #999; font-size: 0.9rem; }
    </style>
</head>
<body>

    <header class="admin-header">
        <div class="container d-flex justify-content-between align-items-center">
            <h4 class="mb-0 fw-bold"><i class="fas fa-users me-2"></i> QUẢN LÝ NGƯỜI DÙNG</h4>
            <div>
                <a href="/admin" class="btn btn-sm btn-outline-light me-2"><i class="fas fa-home me-1"></i> Dashboard</a>
                <a href="/admin/user/add" class="btn btn-sm btn-warning fw-bold"><i class="fas fa-plus me-1"></i> Thêm mới</a>
            </div>
        </div>
    </header>

    <div class="container pb-5">
        <div class="card">
            <div class="card-body">
                <table class="table table-hover align-middle">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Tên đăng nhập</th>
                            <th>Họ tên</th>
                            <th>Email</th>
                            <th>Mật khẩu (Hash)</th>
                            <th>Vai trò</th>
                            <th>Hành động</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (users && users.length > 0) { %>
                            <% users.forEach(u => {
                                // Chuẩn hóa role về chữ thường để so sánh
                                let role = u.role ? u.role.toLowerCase().trim() : 'user';
                            %>
                                <tr>
                                    <td>#<%= u.id %></td>
                                    <td class="fw-bold"><%= u.username %></td>
                                    <td><%= u.full_name || '---' %></td>
                                    <td><%= u.email %></td>
                                    <td class="password-cell" title="<%= u.password %>">
                                        <%= u.password ? u.password.substring(0, 10) + '...' : '******' %>
                                    </td>
                                    <td>
                                        <% if (role === 'admin') { %>
                                            <span class="role-badge role-admin">Admin</span>
                                        <% } else { %>
                                            <span class="role-badge role-user">User</span>
                                        <% } %>
                                    </td>
                                    <td>
                                        <button class="btn btn-sm btn-danger" title="Xóa" onclick="showConfirmModal('/admin/user/delete/<%= u.id %>', 'Bạn có chắc chắn muốn xóa người dùng này?')">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </td>
                                </tr>
                            <% }); %>
                        <% } else { %>
                            <tr>
                                <td colspan="7" class="text-center py-4 text-muted">Chưa có người dùng nào.</td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <%- include('../partials/confirm_modal') %>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>