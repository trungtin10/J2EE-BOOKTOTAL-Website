<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <title>Đăng ký - Bookstore</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        body { background-color: #f0f2f5; font-family: 'Segoe UI', sans-serif; display: flex; flex-direction: column; min-height: 100vh; }
        .main-content { flex: 1; display: flex; align-items: center; justify-content: center; padding: 50px 0; }
        .auth-card { background: white; padding: 40px; border-radius: 12px; box-shadow: 0 4px 20px rgba(0,0,0,0.05); width: 100%; max-width: 450px; }
        .auth-title { font-weight: 800; color: #C92127; text-align: center; margin-bottom: 30px; font-size: 1.8rem; }
        .form-control { padding: 12px; border-radius: 8px; }
        .btn-auth { background-color: #C92127; color: white; font-weight: 700; padding: 12px; border-radius: 8px; width: 100%; border: none; transition: 0.3s; }
        .btn-auth:hover { background-color: #a11b20; }
    </style>
</head>
<body>
    <%- include('../partials/menu') %>

    <div class="main-content">
        <div class="auth-card">
            <h2 class="auth-title">ĐĂNG KÝ</h2>

            <% if (locals.registerError) { %>
                <div class="alert alert-danger text-center"><%= registerError %></div>
            <% } %>

            <form action="/register" method="POST">
                <div class="mb-3">
                    <label class="form-label fw-bold">Họ và tên</label>
                    <input type="text" class="form-control" name="full_name" required>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-bold">Email</label>
                    <input type="email" class="form-control" name="email" required>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-bold">Tên đăng nhập</label>
                    <input type="text" class="form-control" name="username" required>
                </div>
                <div class="mb-4">
                    <label class="form-label fw-bold">Mật khẩu</label>
                    <input type="password" class="form-control" name="password" required>
                </div>

                <input type="hidden" name="role" value="user">

                <button type="submit" class="btn-auth">ĐĂNG KÝ</button>
            </form>

            <div class="text-center mt-4">
                <p class="text-muted">Đã có tài khoản? <a href="/login" class="text-decoration-none fw-bold text-danger">Đăng nhập ngay</a></p>
            </div>
        </div>
    </div>

    <%- include('../partials/footer') %>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>