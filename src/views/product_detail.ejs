<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8">
    <title>
        <%= product.name %> - Bookstore
    </title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/css/product-detail.css">
    <style>
        /* Style riêng cho Modal Đánh giá */
        .rating-stars-input {
            display: flex;
            flex-direction: row-reverse;
            justify-content: center;
            gap: 10px;
        }

        .rating-stars-input input {
            display: none;
        }

        .rating-stars-input label {
            font-size: 2rem;
            color: #ddd;
            cursor: pointer;
            transition: color 0.2s;
        }

        .rating-stars-input input:checked~label,
        .rating-stars-input label:hover,
        .rating-stars-input label:hover~label {
            color: #FFD700;
        }

        .rating-text {
            text-align: center;
            margin-top: 5px;
            font-weight: 600;
            color: #555;
            min-height: 24px;
        }

        /* Filter Bar */
        .review-filter {
            display: flex;
            gap: 10px;
            margin-bottom: 20px;
            flex-wrap: wrap;
        }

        .filter-btn {
            border: 1px solid #eee;
            background: #f8f9fa;
            padding: 5px 15px;
            border-radius: 20px;
            font-size: 0.85rem;
            color: #555;
            cursor: pointer;
            transition: 0.2s;
        }

        .filter-btn.active,
        .filter-btn:hover {
            background: #fff3cd;
            border-color: #ffc107;
            color: #856404;
            font-weight: 600;
        }

        /* Review Item */
        .review-item {
            display: flex;
            gap: 15px;
            border-bottom: 1px solid #f0f0f0;
            padding: 20px 0;
        }

        .review-avatar {
            width: 45px;
            height: 45px;
            background: #eee;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: bold;
            color: #777;
            font-size: 1.2rem;
        }

        .review-content {
            flex: 1;
        }

        .review-header {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 5px;
        }

        .review-name {
            font-weight: 600;
            color: #333;
            font-size: 0.95rem;
        }

        .verified-badge {
            font-size: 0.75rem;
            color: #2ecc71;
            display: flex;
            align-items: center;
            gap: 3px;
        }

        .review-stars {
            color: #FFD700;
            font-size: 0.85rem;
            margin-bottom: 8px;
        }

        .review-text {
            color: #444;
            font-size: 0.95rem;
            line-height: 1.5;
            margin-bottom: 5px;
        }

        .review-date {
            font-size: 0.8rem;
            color: #999;
        }

        /* Admin Reply */
        .admin-reply-box {
            background-color: #f8f9fa;
            border-left: 3px solid #C92127;
            padding: 10px 15px;
            margin-top: 10px;
            border-radius: 0 4px 4px 0;
        }

        .admin-reply-header {
            font-weight: 700;
            color: #C92127;
            font-size: 0.85rem;
            margin-bottom: 5px;
            display: flex;
            align-items: center;
            gap: 5px;
        }

        .admin-reply-content {
            font-size: 0.9rem;
            color: #555;
        }

        /* Popup */
        .center-success-popup {
            position: fixed;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%) scale(0.8);
            background-color: white;
            padding: 30px 40px;
            border-radius: 12px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.15);
            z-index: 9999;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            opacity: 0;
            visibility: hidden;
            transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            min-width: 300px;
        }

        .center-success-popup.show {
            opacity: 1;
            visibility: visible;
            transform: translate(-50%, -50%) scale(1);
        }

        .center-success-popup i {
            font-size: 3.5rem;
            color: #2ecc71;
            margin-bottom: 15px;
        }

        .center-success-popup span {
            font-size: 1.1rem;
            font-weight: 700;
            color: #2ecc71;
        }

        /* Shipping */
        .shipping-info {
            font-size: 0.9rem;
            margin-bottom: 20px;
            padding-bottom: 15px;
            border-bottom: 1px dashed #eee;
        }

        .shipping-row {
            display: flex;
            align-items: flex-start;
            margin-bottom: 10px;
        }

        .shipping-label {
            color: #333;
            font-weight: 600;
            margin-right: 5px;
            white-space: nowrap;
        }

        .shipping-address {
            font-weight: 700;
            color: #2489F4;
            margin-right: 10px;
            cursor: pointer;
        }

        .btn-change-address {
            color: #C92127;
            text-decoration: none;
            font-weight: 600;
            font-size: 0.85rem;
            cursor: pointer;
            text-transform: uppercase;
        }

        .btn-change-address:hover {
            text-decoration: underline;
        }

        .shipping-estimate {
            font-weight: 700;
            color: #2ecc71;
            font-size: 0.95rem;
        }

        /* Modal Address */
        .address-select-group {
            margin-bottom: 15px;
        }

        .address-select-group label {
            font-weight: 600;
            font-size: 0.9rem;
            margin-bottom: 5px;
            display: block;
        }

        /* Rating Summary */
        .rating-summary-top {
            display: flex;
            align-items: center;
            font-size: 0.9rem;
            margin-bottom: 15px;
            color: #555;
        }

        .rating-stars-top {
            color: #FFD700;
            margin-right: 5px;
        }

        .divider {
            margin: 0 10px;
            color: #ddd;
        }

        /* Meta Info */
        .meta-info-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            column-gap: 30px;
            row-gap: 10px;
            margin-bottom: 20px;
            font-size: 0.95rem;
        }

        .meta-item {
            display: flex;
            align-items: baseline;
        }

        .meta-label {
            color: #777;
            width: 110px;
            flex-shrink: 0;
        }

        .highlight-text {
            color: #2489F4 !important;
            font-weight: 600;
            text-decoration: none;
        }

        .highlight-text:hover {
            text-decoration: underline;
        }

        .meta-value {
            font-weight: 600;
            color: #333;
        }

        /* Admin Badge */
        .admin-mode-badge {
            background-color: #1a1a2e;
            color: #c49b63;
            padding: 10px;
            border-radius: 8px;
            text-align: center;
            font-weight: 600;
            margin-bottom: 20px;
            border: 1px dashed #c49b63;
        }
    </style>
</head>

<body>
    <%- include('partials/menu') %>

        <!-- POPUP THÔNG BÁO -->
        <div id="centerSuccessPopup" class="center-success-popup">
            <i class="fas fa-check-circle"></i>
            <span>Đã thêm vào giỏ hàng thành công!</span>
        </div>

        <div class="container mt-4 mb-5">
            <!-- Breadcrumb -->
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb bg-white shadow-sm p-3 rounded">
                    <li class="breadcrumb-item"><a href="/">Trang chủ</a></li>
                    <li class="breadcrumb-item"><a href="#">
                            <%= product.category_name || 'Sách' %>
                        </a></li>
                    <li class="breadcrumb-item active">
                        <%= product.name %>
                    </li>
                </ol>
            </nav>

            <div class="row mb-4">
                <!-- CỘT TRÁI -->
                <div class="col-lg-4 col-md-5">
                    <div class="content-box left-sidebar bg-white p-3 rounded shadow-sm mb-3">
                        <div class="product-img-box text-center mb-3">
                            <% let imgSrc=product.image_url; if (imgSrc && !imgSrc.startsWith('http')) imgSrc='/images/'
                                + imgSrc; %>
                                <img src="<%= imgSrc || '/images/default.jpg' %>" class="product-img img-fluid rounded"
                                    alt="<%= product.name %>" onerror="this.src='https://picsum.photos/400/600'">
                        </div>

                        <% if (locals.user && user.role==='admin' ) { %>
                            <div class="admin-mode-badge">
                                <i class="fas fa-user-shield me-2"></i> Chế độ Admin (Chỉ xem)
                            </div>
                            <div class="action-buttons d-grid gap-2">
                                <button class="btn btn-secondary py-2" disabled
                                    style="cursor: not-allowed; opacity: 0.6;">
                                    <i class="fas fa-ban me-2"></i> Không thể mua hàng
                                </button>
                            </div>
                            <% } else { %>
                                <div class="action-buttons d-grid gap-2">
                                    <button class="btn btn-outline-danger py-2 fw-bold" id="btnAddToCart"
                                        data-id="<%= product.id %>">
                                        <i class="fas fa-cart-plus"></i> Thêm giỏ hàng
                                    </button>
                                    <button class="btn btn-danger py-2 fw-bold" id="btnBuyNow"
                                        data-id="<%= product.id %>">
                                        Mua ngay
                                    </button>
                                </div>
                                <% } %>

                                    <div class="policy-box mt-3 pt-3 border-top">
                                        <ul class="list-unstyled small text-muted">
                                            <li class="mb-2"><i class="fas fa-truck text-success me-2"></i> Miễn phí
                                                giao hàng đơn từ 150k</li>
                                            <li class="mb-2"><i class="fas fa-undo text-primary me-2"></i> Đổi trả miễn
                                                phí trong 30 ngày</li>
                                            <li><i class="fas fa-check-shield text-warning me-2"></i> Cam kết chính hãng
                                                100%</li>
                                        </ul>
                                    </div>
                    </div>
                </div>

                <!-- CỘT PHẢI -->
                <div class="col-lg-8 col-md-7">
                    <div class="content-box bg-white p-4 rounded shadow-sm mb-3">
                        <h1 class="product-title h3 fw-bold mb-3">
                            <%= product.name %>
                        </h1>

                        <div class="meta-info-grid">
                            <div class="meta-item"><span class="meta-label">Nhà cung cấp:</span><span
                                    class="meta-value"><a href="#" class="highlight-text">
                                        <%= product.supplier_name || 'Đang cập nhật' %>
                                    </a></span></div>
                            <div class="meta-item"><span class="meta-label">Tác giả:</span><span class="meta-value"><a
                                        href="#" class="highlight-text">
                                        <%= product.author_name || 'Đang cập nhật' %>
                                    </a></span></div>
                            <div class="meta-item"><span class="meta-label">Nhà xuất bản:</span><span
                                    class="meta-value">
                                    <%= product.publisher_name || '---' %>
                                </span></div>
                            <div class="meta-item"><span class="meta-label">Hình thức bìa:</span><span
                                    class="meta-value">
                                    <%= product.cover_type || '---' %>
                                </span></div>
                        </div>

                        <div class="rating-summary-top mb-3">
                            <div class="text-warning me-2">
                                <i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i
                                    class="fas fa-star"></i><i class="fas fa-star"></i>
                            </div>
                            <span class="text-muted">(<%= reviews ? reviews.length : 0 %> đánh giá)</span>
                            <span class="mx-2 text-muted">|</span>
                            <span class="text-muted">Đã bán <%= product.sold_count || 0 %></span>
                        </div>

                        <div class="price-box my-3">
                            <span class="current-price h2 text-danger fw-bold me-3">
                                <%= Number(product.price).toLocaleString('vi-VN') %> đ
                            </span>
                            <% if (product.quantity> 0) { %>
                                <span class="badge bg-success"><i class="fas fa-check"></i> Còn hàng</span>
                                <% } else { %>
                                    <span class="badge bg-secondary">Hết hàng</span>
                                    <% } %>
                        </div>

                        <div class="shipping-info">
                            <div class="shipping-row align-items-center">
                                <span class="shipping-label">Giao hàng đến:</span>
                                <span class="shipping-address" id="currentAddress">Hồ Chí Minh</span>
                                <span class="btn-change-address ms-2" data-bs-toggle="modal"
                                    data-bs-target="#addressModal">Thay đổi</span>
                            </div>
                            <div class="shipping-row">
                                <i class="fas fa-truck-fast text-success me-2 mt-1"></i>
                                <div class="shipping-estimate" id="deliveryDate">Đang tính toán...</div>
                            </div>
                        </div>

                        <div class="d-flex align-items-center gap-3 mb-3">
                            <span class="fw-bold">Số lượng:</span>
                            <div class="input-group input-group-sm" style="width: 120px;">
                                <button class="btn btn-outline-secondary" type="button"
                                    onclick="decreaseQty()">-</button>
                                <input type="text" class="form-control text-center fw-bold" value="1" id="qtyInput">
                                <button class="btn btn-outline-secondary" type="button"
                                    onclick="increaseQty()">+</button>
                            </div>
                        </div>
                    </div>

                    <!-- MÔ TẢ SẢN PHẨM -->
                    <div class="content-box bg-white p-4 rounded shadow-sm mb-3">
                        <h5 class="fw-bold mb-3 border-bottom pb-2">Mô tả sản phẩm</h5>
                        <div class="text-secondary"
                            style="line-height: 1.6; text-align: justify; white-space: pre-wrap;">
                            <%= product.description || "Đang cập nhật nội dung..." %>
                        </div>
                    </div>
                </div>
            </div>

            <!-- ĐÁNH GIÁ KHÁCH HÀNG -->
            <div class="content-box bg-white p-4 rounded shadow-sm">
                <h5 class="fw-bold mb-3">Đánh giá khách hàng</h5>

                <div class="rating-overview">
                    <div class="rating-left">
                        <% let total=reviews ? reviews.reduce((sum, r)=> sum + r.rating, 0) : 0;
                            let avgRating = reviews && reviews.length > 0 ? (total / reviews.length).toFixed(1) : 0;
                            %>
                            <div class="rating-score">
                                <%= avgRating %>/5
                            </div>
                            <div class="text-warning mb-1">
                                <% for(let i=1; i<=5; i++) { %>
                                    <% if(i <=Math.round(avgRating)) { %><i class="fas fa-star"></i>
                                        <% } else { %><i class="far fa-star"></i>
                                            <% } %>
                                                <% } %>
                            </div>
                            <div class="text-muted small">(<%= reviews ? reviews.length : 0 %> đánh giá)</div>
                    </div>

                    <div class="rating-right">
                        <% for(let i=5; i>=1; i--) {
                            let count = reviews ? reviews.filter(r => r.rating == i).length : 0;
                            let percent = reviews && reviews.length > 0 ? (count / reviews.length * 100) : 0;
                            %>
                            <div class="d-flex align-items-center mb-1 small text-muted">
                                <span style="width: 40px">
                                    <%= i %> sao
                                </span>
                                <div class="progress">
                                    <div class="progress-bar" style="width: <%= percent %>%"></div>
                                </div>
                                <span style="width: 30px; text-align: right">
                                    <%= percent.toFixed(0) %>%
                                </span>
                            </div>
                            <% } %>
                    </div>
                </div>

                <div class="d-flex justify-content-between align-items-center mb-4">
                    <div class="review-filter">
                        <div class="filter-btn active">Tất cả</div>
                        <div class="filter-btn">5 Sao</div>
                        <div class="filter-btn">4 Sao</div>
                        <div class="filter-btn">3 Sao</div>
                    </div>

                    <% if (locals.user) { %>
                        <% if (user.role==='admin' ) { %>
                            <button class="btn btn-secondary btn-sm px-4" disabled>Admin không thể đánh giá</button>
                            <% } else { %>
                                <button class="btn btn-primary btn-sm px-4" data-bs-toggle="modal"
                                    data-bs-target="#reviewModal">
                                    <i class="fas fa-pen me-2"></i> Viết đánh giá
                                </button>
                                <% } %>
                                    <% } else { %>
                                        <button class="btn btn-outline-danger btn-sm" onclick="openLoginModal()">Đăng
                                            nhập để đánh giá</button>
                                        <% } %>
                </div>

                <div class="review-list">
                    <% if (reviews && reviews.length> 0) { %>
                        <% reviews.forEach(review=> { %>
                            <div class="review-item">
                                <div class="review-avatar">
                                    <%= review.full_name ? review.full_name.charAt(0).toUpperCase() : 'U' %>
                                </div>
                                <div class="review-content">
                                    <div class="review-header">
                                        <span class="review-name">
                                            <%= review.full_name || 'Người dùng ẩn danh' %>
                                        </span>
                                        <span class="verified-badge"><i class="fas fa-check-circle"></i> Đã mua
                                            hàng</span>
                                    </div>
                                    <div class="review-stars text-warning">
                                        <% for(let i=0; i<review.rating; i++) { %>★<% } %>
                                                <% for(let i=review.rating; i<5; i++) { %>☆<% } %>
                                    </div>
                                    <div class="review-text">
                                        <%= review.comment %>
                                    </div>
                                    <div class="review-date">
                                        <%= new Date(review.created_at).toLocaleDateString('vi-VN') %>
                                    </div>

                                    <% if (review.admin_reply) { %>
                                        <div class="admin-reply-box">
                                            <div class="admin-reply-header"><i class="fas fa-user-shield"></i> Phản hồi
                                                từ Quản trị viên</div>
                                            <div class="admin-reply-content">
                                                <%= review.admin_reply %>
                                            </div>
                                        </div>
                                        <% } %>
                                </div>
                            </div>
                            <% }); %>
                                <% } else { %>
                                    <p class="text-muted text-center py-3 small">Chưa có đánh giá nào.</p>
                                    <% } %>
                </div>
            </div>
        </div>

        <!-- Modal Viết Đánh Giá -->
        <div class="modal fade" id="reviewModal" tabindex="-1" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content">
                    <div class="modal-header border-0 pb-0">
                        <h5 class="modal-title fw-bold">Viết đánh giá sản phẩm</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        <form action="/product/<%= product.id %>/review" method="POST">
                            <div class="text-center mb-3">
                                <p class="mb-2 text-muted small">Bạn cảm thấy sản phẩm này như thế nào?</p>
                                <div class="rating-stars-input">
                                    <input type="radio" id="star5" name="rating" value="5" checked
                                        onclick="setRatingText('Tuyệt vời')"><label for="star5"
                                        title="Tuyệt vời">★</label>
                                    <input type="radio" id="star4" name="rating" value="4"
                                        onclick="setRatingText('Hài lòng')"><label for="star4"
                                        title="Hài lòng">★</label>
                                    <input type="radio" id="star3" name="rating" value="3"
                                        onclick="setRatingText('Bình thường')"><label for="star3"
                                        title="Bình thường">★</label>
                                    <input type="radio" id="star2" name="rating" value="2"
                                        onclick="setRatingText('Tệ')"><label for="star2" title="Tệ">★</label>
                                    <input type="radio" id="star1" name="rating" value="1"
                                        onclick="setRatingText('Rất tệ')"><label for="star1" title="Rất tệ">★</label>
                                </div>
                                <div id="ratingText" class="rating-text">Tuyệt vời</div>
                            </div>

                            <div class="mb-3">
                                <textarea name="comment" class="form-control" rows="4"
                                    placeholder="Hãy chia sẻ cảm nhận của bạn về sản phẩm này nhé..."
                                    required></textarea>
                            </div>

                            <div class="d-grid">
                                <button type="submit" class="btn btn-danger fw-bold py-2">Gửi đánh giá</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>

        <!-- Modal Chọn Địa Chỉ -->
        <div class="modal fade" id="addressModal" tabindex="-1" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content">
                    <div class="modal-header border-0 pb-0">
                        <h5 class="modal-title fw-bold">Chọn địa chỉ giao hàng</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        <div class="address-select-group">
                            <label>Tỉnh/Thành phố</label>
                            <select class="form-select" id="provinceSelect" onchange="updateDistricts()">
                                <option value="Hồ Chí Minh">Hồ Chí Minh</option>
                                <option value="Hà Nội">Hà Nội</option>
                                <option value="Đà Nẵng">Đà Nẵng</option>
                                <option value="Cần Thơ">Cần Thơ</option>
                            </select>
                        </div>
                        <div class="address-select-group">
                            <label>Quận/Huyện</label>
                            <select class="form-select" id="districtSelect">
                                <option value="Quận 1">Quận 1</option>
                                <option value="Quận 3">Quận 3</option>
                                <option value="Thủ Đức">Thủ Đức</option>
                            </select>
                        </div>
                        <div class="address-select-group">
                            <label>Phường/Xã</label>
                            <select class="form-select" id="wardSelect">
                                <option value="Phường Bến Nghé">Phường Bến Nghé</option>
                                <option value="Phường Đa Kao">Phường Đa Kao</option>
                            </select>
                        </div>
                        <div class="d-grid mt-4">
                            <button type="button" class="btn btn-danger fw-bold" onclick="saveAddress()">Xác
                                nhận</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <%- include('partials/footer') %>

            <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
            <script src="/js/product-detail.js"></script>
            <script>
                function openLoginModal() {
                    const currentUrl = window.location.pathname;
                    const loginForm = document.querySelector('#loginModal form');
                    if (loginForm) {
                        if (!loginForm.querySelector('input[name="returnUrl"]')) {
                            const input = document.createElement('input');
                            input.type = 'hidden';
                            input.name = 'returnUrl';
                            input.value = currentUrl;
                            loginForm.appendChild(input);
                        } else {
                            loginForm.querySelector('input[name="returnUrl"]').value = currentUrl;
                        }
                        const loginModal = new bootstrap.Modal(document.getElementById('loginModal'));
                        loginModal.show();
                    }
                }
            </script>
</body>

</html>